generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  draft
  active
  closed
}

enum TicketStatus {
  available
  assigned
  reserved
  sold
  paid
  used
  void
}

enum PaymentMethod {
  transfer
  cash
}

enum EvidenceStatus {
  pending
  approved
  rejected
}

enum UserRole {
  admin
  seller
  gate
}

enum UserStatus {
  active
  disabled
}

model AppUser {
  id           String     @id @default(uuid()) @db.VarChar(36)
  email        String     @unique @db.VarChar(160)
  name         String     @db.VarChar(120)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  role         UserRole   @default(seller)
  status       UserStatus @default(active)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([role])
  @@index([status])
  @@map("app_users")
}

model Event {
  id                String            @id @default(uuid()) @db.VarChar(36)
  name              String            @db.VarChar(120)
  date              DateTime
  venue             String            @db.VarChar(160)
  status            EventStatus       @default(draft)
  expectedAttendees Int               @default(0) @map("expected_attendees")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  distributors      Distributor[]
  tickets           Ticket[]
  paymentEvidences  PaymentEvidence[]
  auditLogs         AuditLog[]

  @@map("events")
}

model Distributor {
  id        String   @id @default(uuid()) @db.VarChar(36)
  eventId   String   @map("event_id") @db.VarChar(36)
  name      String   @db.VarChar(120)
  phone     String   @db.VarChar(40)
  email     String?  @db.VarChar(160)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Restrict)
  tickets   Ticket[]

  @@index([eventId])
  @@map("distributors")
}

model Ticket {
  id                   String            @id @default(uuid()) @db.VarChar(36)
  eventId              String            @map("event_id") @db.VarChar(36)
  code                 String            @db.VarChar(40)
  price                Int
  status               TicketStatus      @default(available)
  distributorId        String?           @map("distributor_id") @db.VarChar(36)
  recipientName        String?           @map("recipient_name") @db.VarChar(120)
  buyerName            String?           @map("buyer_name") @db.VarChar(120)
  buyerPhone           String?           @map("buyer_phone") @db.VarChar(40)
  paymentMethod        PaymentMethod?    @map("payment_method")
  soldAt               DateTime?         @map("sold_at")
  paidAt               DateTime?         @map("paid_at")
  usedAt               DateTime?         @map("used_at")
  checkedInBy          String?           @map("checked_in_by") @db.VarChar(120)
  capitalizationAmount Int               @default(0) @map("capitalization_amount")
  notes                String?           @db.Text
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  event                Event             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  distributor          Distributor?      @relation(fields: [distributorId], references: [id], onDelete: SetNull)
  paymentEvidences     PaymentEvidence[]

  @@unique([eventId, code])
  @@index([distributorId])
  @@index([status])
  @@map("tickets")
}

model PaymentEvidence {
  id                   String         @id @default(uuid()) @db.VarChar(36)
  eventId              String         @map("event_id") @db.VarChar(36)
  ticketId             String         @map("ticket_id") @db.VarChar(36)
  method               PaymentMethod
  amount               Int
  capitalizationAmount Int            @default(0) @map("capitalization_amount")
  evidenceUrl          String?        @map("evidence_url") @db.VarChar(500)
  reference            String?        @db.VarChar(120)
  status               EvidenceStatus @default(pending)
  receivedAt           DateTime       @default(now()) @map("received_at")
  reviewedAt           DateTime?      @map("reviewed_at")
  reviewedBy           String?        @map("reviewed_by") @db.VarChar(120)
  notes                String?        @db.Text
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  event                Event          @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticket               Ticket         @relation(fields: [ticketId], references: [id], onDelete: Restrict)

  @@index([eventId])
  @@index([ticketId])
  @@index([status])
  @@map("payment_evidences")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.VarChar(36)
  eventId    String?  @map("event_id") @db.VarChar(36)
  entityType String   @map("entity_type") @db.VarChar(60)
  entityId   String   @map("entity_id") @db.VarChar(36)
  action     String   @db.VarChar(80)
  fromStatus String?  @map("from_status") @db.VarChar(40)
  toStatus   String?  @map("to_status") @db.VarChar(40)
  actor      String?  @db.VarChar(120)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  event      Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
