---
interface TicketRow {
  reference: string;
  detail: string;
  distributor: string;
  status: "Disponible" | "Asignada" | "Reservada" | "Vendida" | "Pagada" | "Usada" | "Bloqueada";
  amount: string;
}

interface Props {
  rows: ReadonlyArray<TicketRow>;
}

const { rows } = Astro.props;

const statusClasses = {
  Asignada: "bg-zinc-100 text-zinc-700",
  Bloqueada: "bg-rose-50 text-rose-700",
  Disponible: "bg-sky-50 text-sky-700",
  Pagada: "bg-emerald-50 text-emerald-700",
  Reservada: "bg-violet-50 text-violet-700",
  Usada: "bg-indigo-50 text-indigo-700",
  Vendida: "bg-amber-50 text-amber-700"
};
---

<section class="rounded-lg border border-zinc-200 bg-white shadow-sm">
  <div class="flex flex-col gap-3 border-b border-zinc-200 p-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-sm font-semibold text-zinc-950">Boletas</h2>
      <p class="mt-1 text-xs text-zinc-500">Estado operativo de inventario</p>
    </div>
    <div class="flex items-center gap-2">
      <button class="h-9 rounded-md border border-zinc-200 px-3 text-xs font-medium text-zinc-700 hover:bg-zinc-50">
        Filtrar
      </button>
      <button class="hidden h-9 items-center rounded-md bg-zinc-950 px-3 text-xs font-medium text-white hover:bg-zinc-800" data-admin-only data-role-display="inline-flex">
        Nueva
      </button>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-zinc-100 text-left text-sm">
      <thead class="bg-zinc-50 text-xs uppercase text-zinc-500">
        <tr>
          <th class="px-4 py-3 font-medium">Referencia</th>
          <th class="px-4 py-3 font-medium">Detalle</th>
          <th class="px-4 py-3 font-medium">Distribuidor</th>
          <th class="px-4 py-3 font-medium">Estado</th>
          <th class="px-4 py-3 text-right font-medium">Valor</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-100 bg-white">
        {
          rows.map((row) => (
            <tr class="hover:bg-zinc-50">
              <td class="whitespace-nowrap px-4 py-3 font-medium text-zinc-950">
                {row.reference}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-zinc-600">{row.detail}</td>
              <td class="whitespace-nowrap px-4 py-3 text-zinc-600">
                {row.distributor}
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <span class={`rounded-md px-2 py-1 text-xs font-medium ${statusClasses[row.status]}`}>
                  {row.status}
                </span>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right font-semibold text-zinc-950">
                {row.amount}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>
