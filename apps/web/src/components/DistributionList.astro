---
interface DistributorRow {
  name: string;
  tickets: number;
  paid: number;
  used: number;
  amount: string;
}

interface Props {
  rows: ReadonlyArray<DistributorRow>;
}

const { rows } = Astro.props;
---

<section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
  <div class="flex items-center justify-between gap-3">
    <div>
      <h2 class="text-sm font-semibold text-zinc-950">Distribucion</h2>
      <p class="mt-1 text-xs text-zinc-500">Asignacion y recaudo por responsable</p>
    </div>
    <button class="inline-flex h-9 items-center rounded-md border border-zinc-200 px-3 text-xs font-medium text-zinc-700 hover:bg-zinc-50">
      Ver todo
    </button>
  </div>

  <div class="mt-4 divide-y divide-zinc-100">
    {
      rows.map((row) => (
        <div class="grid grid-cols-[1fr_auto] gap-3 py-3">
          <div>
            <p class="text-sm font-medium text-zinc-950">{row.name}</p>
            <p class="mt-1 text-xs text-zinc-500">
              {row.tickets} asignadas - {row.paid} pagadas - {row.used} usadas
            </p>
          </div>
          <div class="text-right">
            <p class="text-sm font-semibold text-zinc-950">{row.amount}</p>
            <p class="mt-1 text-xs text-emerald-700">Recaudado</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
