---
interface PaymentEvidenceRow {
  buyer: string;
  method: string;
  amount: string;
  status: "Aprobado" | "Pendiente" | "Rechazado";
  reference: string;
}

interface Props {
  rows: ReadonlyArray<PaymentEvidenceRow>;
}

const { rows } = Astro.props;

const statusClasses = {
  Aprobado: "bg-emerald-50 text-emerald-700 ring-emerald-200",
  Pendiente: "bg-amber-50 text-amber-700 ring-amber-200",
  Rechazado: "bg-rose-50 text-rose-700 ring-rose-200"
};
---

<section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
  <div class="flex items-center justify-between gap-3">
    <div>
      <h2 class="text-sm font-semibold text-zinc-950">Evidencias</h2>
      <p class="mt-1 text-xs text-zinc-500">Transferencias y efectivo por validar</p>
    </div>
    <button class="inline-flex h-9 items-center rounded-md border border-zinc-200 px-3 text-xs font-medium text-zinc-700 hover:bg-zinc-50">
      Revisar
    </button>
  </div>

  <div class="mt-4 divide-y divide-zinc-100">
    {
      rows.map((row) => (
        <article class="py-3 first:pt-0 last:pb-0">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-medium text-zinc-950">{row.buyer}</p>
              <p class="mt-1 text-xs text-zinc-500">
                {row.method} · {row.reference}
              </p>
            </div>
            <span class={`rounded-md px-2 py-1 text-xs font-medium ring-1 ${statusClasses[row.status]}`}>
              {row.status}
            </span>
          </div>
          <p class="mt-3 text-sm font-semibold text-zinc-950">{row.amount}</p>
        </article>
      ))
    }
  </div>
</section>
