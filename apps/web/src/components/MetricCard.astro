---
interface Props {
  label: string;
  value: string;
  detail: string;
  tone: "emerald" | "amber" | "rose" | "zinc";
  icon: any;
  detailField?: string;
  valueField?: string;
}

const { detail, detailField, icon: Icon, label, tone, value, valueField } = Astro.props;

const toneClasses = {
  amber: "bg-amber-50 text-amber-700 ring-amber-200",
  emerald: "bg-emerald-50 text-emerald-700 ring-emerald-200",
  rose: "bg-rose-50 text-rose-700 ring-rose-200",
  zinc: "bg-zinc-100 text-zinc-700 ring-zinc-200"
};
---

<section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs font-medium uppercase text-zinc-500">{label}</p>
      <p class="mt-2 text-2xl font-semibold text-zinc-950" data-dashboard-field={valueField}>{value}</p>
    </div>
    <span class={`inline-flex h-9 w-9 items-center justify-center rounded-md ring-1 ${toneClasses[tone]}`}>
      <Icon size={18} stroke-width={2} />
    </span>
  </div>
  <p class="mt-3 text-xs text-zinc-500" data-dashboard-field={detailField}>{detail}</p>
</section>
