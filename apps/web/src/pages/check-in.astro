---
import {
  CalendarDays,
  LogOut,
  RefreshCw,
  ScanLine,
  Search,
  ShieldCheck,
  Ticket,
  UserRoundCheck
} from "lucide-astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? "/api";
const authMeUrl = `${apiBase}/auth/me`;
const eventsUrl = `${apiBase}/events`;
const ticketsUrl = `${apiBase}/tickets`;
---

<BaseLayout title="Entrada | Boletas">
  <span
    hidden
    data-auth-me-url={authMeUrl}
    data-events-url={eventsUrl}
    data-tickets-url={ticketsUrl}
  ></span>
  <script>
    type EventStatus = "draft" | "active" | "closed";
    type PaymentMethod = "cash" | "transfer";
    type TicketStatus =
      | "assigned"
      | "available"
      | "paid"
      | "reserved"
      | "sold"
      | "used"
      | "void";
    type UserRole = "regular" | "supervisor" | "admin";

    interface StoredUser {
      id: string;
      email: string;
      name: string;
      role: UserRole;
    }

    interface EventRecord {
      id: string;
      name: string;
      date: string;
      venue: string;
      status: EventStatus;
      expectedAttendees: number;
      createdAt: string;
    }

    interface TicketRecord {
      id: string;
      eventId: string;
      code: string;
      price: number;
      status: TicketStatus;
      distributorId?: string;
      distributorName?: string;
      distributorPhone?: string;
      distributorEmail?: string;
      distributorNotes?: string;
      recipientName?: string;
      buyerName?: string;
      buyerPhone?: string;
      paymentMethod?: PaymentMethod;
      soldAt?: string;
      paidAt?: string;
      usedAt?: string;
      checkedInBy?: string;
      capitalizationAmount: number;
      notes?: string;
      createdAt: string;
    }

    interface AuthMeResponse {
      user?: StoredUser;
    }

    const allowedRoles = new Set(["regular", "supervisor", "admin"]);
    const allowedEventStatuses = new Set(["draft", "active", "closed"]);
    const allowedTicketStatuses = new Set([
      "assigned",
      "available",
      "paid",
      "reserved",
      "sold",
      "used",
      "void"
    ]);
    const allowedPaymentMethods = new Set(["cash", "transfer"]);
    const roleLabels: Record<UserRole, string> = {
      admin: "Admin",
      regular: "Regular",
      supervisor: "Supervisor"
    };
    const ticketStatusLabels: Record<TicketStatus, string> = {
      assigned: "Asignada",
      available: "Disponible",
      paid: "Pagada",
      reserved: "Reservada",
      sold: "Vendida",
      used: "Usada",
      void: "Bloqueada"
    };
    const ticketStatusClasses: Record<TicketStatus, string> = {
      assigned: "bg-zinc-100 text-zinc-700",
      available: "bg-sky-50 text-sky-700",
      paid: "bg-emerald-50 text-emerald-700",
      reserved: "bg-violet-50 text-violet-700",
      sold: "bg-amber-50 text-amber-700",
      used: "bg-indigo-50 text-indigo-700",
      void: "bg-rose-50 text-rose-700"
    };
    const paymentMethodLabels: Record<PaymentMethod, string> = {
      cash: "Efectivo",
      transfer: "Transferencia"
    };

    let authToken = "";
    let currentUser: StoredUser | null = null;
    let currentEvents: EventRecord[] = [];
    let currentTickets: TicketRecord[] = [];
    let selectedEventId = new URLSearchParams(window.location.search)
      .get("eventId")
      ?.trim() ?? "";
    const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);

    const resolveApiUrl = (url: string | null | undefined) => {
      if (!url) {
        return null;
      }

      if (url.startsWith("/api") && localHosts.has(window.location.hostname)) {
        return `http://localhost:3000${url}`;
      }

      return url;
    };

    const clearSession = () => {
      sessionStorage.removeItem("boletas.auth.token");
      sessionStorage.removeItem("boletas.auth.expiresAt");
      sessionStorage.removeItem("boletas.auth.user");
    };

    const redirectToLogin = () => {
      clearSession();
      window.location.replace("/login?reason=session-expired");
    };

    const getConfig = () => {
      const config = document.querySelector<HTMLElement>("[data-auth-me-url]");

      return {
        authMeUrl: resolveApiUrl(config?.dataset.authMeUrl),
        eventsUrl: resolveApiUrl(config?.dataset.eventsUrl),
        ticketsUrl: resolveApiUrl(config?.dataset.ticketsUrl)
      };
    };

    const isStoredUser = (value: unknown): value is StoredUser => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const user = value as Partial<StoredUser>;

      return (
        typeof user.id === "string" &&
        typeof user.email === "string" &&
        typeof user.name === "string" &&
        typeof user.role === "string" &&
        allowedRoles.has(user.role)
      );
    };

    const isEventRecord = (value: unknown): value is EventRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const event = value as Partial<EventRecord>;

      return (
        typeof event.id === "string" &&
        typeof event.name === "string" &&
        typeof event.date === "string" &&
        typeof event.venue === "string" &&
        typeof event.status === "string" &&
        allowedEventStatuses.has(event.status) &&
        typeof event.expectedAttendees === "number" &&
        typeof event.createdAt === "string"
      );
    };

    const isTicketRecord = (value: unknown): value is TicketRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const ticket = value as Partial<TicketRecord>;
      const optionalStringIsValid = (field: unknown) =>
        typeof field === "undefined" || typeof field === "string";
      const paymentMethodIsValid =
        typeof ticket.paymentMethod === "undefined" ||
        (typeof ticket.paymentMethod === "string" &&
          allowedPaymentMethods.has(ticket.paymentMethod));

      return (
        typeof ticket.id === "string" &&
        typeof ticket.eventId === "string" &&
        typeof ticket.code === "string" &&
        typeof ticket.price === "number" &&
        typeof ticket.status === "string" &&
        allowedTicketStatuses.has(ticket.status) &&
        typeof ticket.capitalizationAmount === "number" &&
        typeof ticket.createdAt === "string" &&
        optionalStringIsValid(ticket.distributorName) &&
        optionalStringIsValid(ticket.distributorPhone) &&
        optionalStringIsValid(ticket.recipientName) &&
        optionalStringIsValid(ticket.buyerName) &&
        optionalStringIsValid(ticket.buyerPhone) &&
        optionalStringIsValid(ticket.checkedInBy) &&
        paymentMethodIsValid
      );
    };

    const readStoredUser = (): StoredUser | null => {
      const storedUser = sessionStorage.getItem("boletas.auth.user");

      if (!storedUser) {
        return null;
      }

      try {
        const parsed = JSON.parse(storedUser) as unknown;

        return isStoredUser(parsed) ? parsed : null;
      } catch {
        return null;
      }
    };

    const isExpired = (expiresAt: string | null) => {
      const expiresAtMs = expiresAt ? Date.parse(expiresAt) : Number.NaN;

      return !Number.isFinite(expiresAtMs) || expiresAtMs <= Date.now();
    };

    const whenReady = (callback: () => void) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", callback, { once: true });
      } else {
        callback();
      }
    };

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");

    const renderUser = (user: StoredUser) => {
      currentUser = user;

      document.querySelectorAll("[data-auth-user-name]").forEach((element) => {
        element.textContent = user.name;
      });

      document.querySelectorAll("[data-auth-user-email]").forEach((element) => {
        element.textContent = user.email;
      });

      document.querySelectorAll("[data-auth-user-role]").forEach((element) => {
        element.textContent = roleLabels[user.role];
      });
    };

    const renderAdminOnly = (user: StoredUser) => {
      document.querySelectorAll<HTMLElement>("[data-admin-only]").forEach((element) => {
        element.classList.toggle("hidden", user.role !== "admin");
      });

      document.querySelectorAll<HTMLElement>("[data-manager-only]").forEach((element) => {
        element.classList.toggle("hidden", !["admin", "supervisor"].includes(user.role));
      });
    };

    const bindLogout = () => {
      document.querySelectorAll("[data-logout-button]").forEach((button) => {
        button.addEventListener("click", () => {
          clearSession();
          window.location.replace("/login");
        });
      });
    };

    const setStatus = (message: string, tone: "neutral" | "success" | "error" = "neutral") => {
      const element = document.querySelector<HTMLElement>("[data-checkin-status]");

      if (!element) {
        return;
      }

      const toneClasses = {
        error: "border-rose-200 bg-rose-50 text-rose-700",
        neutral: "border-zinc-200 bg-white text-zinc-600",
        success: "border-emerald-200 bg-emerald-50 text-emerald-700"
      };

      element.className = `rounded-md border px-3 py-2 text-sm ${toneClasses[tone]}`;
      element.textContent = message;
      element.classList.remove("hidden");
    };

    const validateSession = async (url: string, token: string) => {
      const response = await fetch(url, {
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error(`Auth session rejected with ${response.status}`);
      }

      const payload = (await response.json()) as AuthMeResponse;

      if (!isStoredUser(payload.user)) {
        throw new Error("Auth session response did not include a valid user.");
      }

      return payload.user;
    };

    const requestJson = async <T,>(url: string, options: RequestInit = {}) => {
      const response = await fetch(url, {
        ...options,
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${authToken}`,
          ...(options.body ? { "Content-Type": "application/json" } : {}),
          ...options.headers
        }
      });

      if (response.status === 401 || response.status === 403) {
        redirectToLogin();
      }

      if (!response.ok) {
        let message = `Solicitud rechazada con estado ${response.status}.`;

        try {
          const payload = (await response.json()) as { message?: string };

          if (payload.message) {
            message = payload.message;
          }
        } catch {
          // Keep the generic message.
        }

        throw new Error(message);
      }

      return (await response.json()) as T;
    };

    const formatDate = (value?: string) => {
      if (!value) {
        return "Sin registro";
      }

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return "Sin registro";
      }

      return new Intl.DateTimeFormat("es-CO", {
        dateStyle: "medium",
        timeStyle: "short"
      }).format(date);
    };

    const normalizeSearch = (value: string) =>
      value
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .trim();

    const getSearchTerm = () => {
      const input = document.querySelector<HTMLInputElement>("[data-checkin-search]");

      return normalizeSearch(input?.value ?? "");
    };

    const getVisibleTickets = () => {
      const term = getSearchTerm();

      if (!term) {
        return currentTickets;
      }

      return currentTickets.filter((ticket) => {
        const haystack = normalizeSearch(
          [
            ticket.code,
            ticket.buyerName,
            ticket.buyerPhone,
            ticket.recipientName,
            ticket.distributorName,
            ticket.distributorPhone,
            ticket.checkedInBy
          ].join(" ")
        );

        return haystack.includes(term);
      });
    };

    const updateSelectedEvent = (eventId: string) => {
      selectedEventId = eventId;
      const selector = document.querySelector<HTMLSelectElement>("[data-event-selector]");

      if (selector) {
        selector.value = selectedEventId;
      }

      const query = new URLSearchParams(window.location.search);
      query.set("eventId", selectedEventId);
      window.history.replaceState(null, "", `${window.location.pathname}?${query.toString()}`);
    };

    const renderEventOptions = () => {
      const selector = document.querySelector<HTMLSelectElement>("[data-event-selector]");
      const eventName = document.querySelector<HTMLElement>("[data-checkin-event-name]");

      if (!selector) {
        return;
      }

      if (currentEvents.length === 0) {
        selector.innerHTML = `<option value="">Sin eventos</option>`;
        selector.setAttribute("disabled", "true");
        if (eventName) {
          eventName.textContent = "Selecciona un evento";
        }
        return;
      }

      if (!currentEvents.some((event) => event.id === selectedEventId)) {
        selectedEventId = currentEvents[0].id;
      }

      selector.removeAttribute("disabled");
      selector.innerHTML = currentEvents
        .map(
          (event) =>
            `<option value="${escapeHtml(event.id)}"${event.id === selectedEventId ? " selected" : ""}>${escapeHtml(event.name)}</option>`
        )
        .join("");

      if (eventName) {
        const event = currentEvents.find((item) => item.id === selectedEventId);
        eventName.textContent = event?.name ?? "Selecciona un evento";
      }
    };

    const renderMetrics = (tickets: TicketRecord[]) => {
      const paid = tickets.filter((ticket) => ticket.status === "paid").length;
      const used = tickets.filter((ticket) => ticket.status === "used").length;
      const blocked = tickets.filter(
        (ticket) => !["paid", "used"].includes(ticket.status)
      ).length;

      document.querySelectorAll("[data-checkin-total]").forEach((element) => {
        element.textContent = `${tickets.length}`;
      });
      document.querySelectorAll("[data-checkin-ready]").forEach((element) => {
        element.textContent = `${paid}`;
      });
      document.querySelectorAll("[data-checkin-used]").forEach((element) => {
        element.textContent = `${used}`;
      });
      document.querySelectorAll("[data-checkin-blocked]").forEach((element) => {
        element.textContent = `${blocked}`;
      });
    };

    const renderTickets = () => {
      const body = document.querySelector<HTMLElement>("[data-checkin-body]");
      const tickets = getVisibleTickets();

      renderMetrics(currentTickets);

      if (!body) {
        return;
      }

      if (currentTickets.length === 0) {
        body.innerHTML = `
          <tr>
            <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="7">
              Sin boletas para este evento
            </td>
          </tr>
        `;
        return;
      }

      if (tickets.length === 0) {
        body.innerHTML = `
          <tr>
            <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="7">
              Sin coincidencias
            </td>
          </tr>
        `;
        return;
      }

      body.innerHTML = tickets
        .map((ticket) => {
          const statusClass = ticketStatusClasses[ticket.status];
          const statusLabel = ticketStatusLabels[ticket.status];
          const buyer = ticket.buyerName ?? ticket.recipientName ?? "Sin titular";
          const buyerPhone = ticket.buyerPhone
            ? `<p class="mt-1 text-xs text-zinc-500">${escapeHtml(ticket.buyerPhone)}</p>`
            : "";
          const responsible = ticket.distributorName ?? "Sin responsable";
          const responsiblePhone = ticket.distributorPhone
            ? `<p class="mt-1 text-xs text-zinc-500">${escapeHtml(ticket.distributorPhone)}</p>`
            : "";
          const paidAt = ticket.paidAt ? formatDate(ticket.paidAt) : "Sin pago aprobado";
          const entry = ticket.usedAt
            ? `
              <p class="text-sm font-medium text-zinc-950">${escapeHtml(formatDate(ticket.usedAt))}</p>
              <p class="mt-1 text-xs text-zinc-500">${escapeHtml(ticket.checkedInBy ?? "Ingreso registrado")}</p>
            `
            : `<span class="text-sm text-zinc-400">Sin ingreso</span>`;
          const action =
            ticket.status === "paid"
              ? `
                <button
                  class="inline-flex h-9 items-center rounded-md bg-emerald-600 px-3 text-sm font-medium text-white hover:bg-emerald-700"
                  data-check-in-ticket="${escapeHtml(ticket.id)}"
                  type="button"
                >
                  Registrar ingreso
                </button>
              `
              : ticket.status === "used"
                ? `<span class="text-xs font-medium text-indigo-700">Ya ingresada</span>`
                : `<span class="text-xs text-zinc-400">No permitida</span>`;

          return `
            <tr class="align-top hover:bg-zinc-50">
              <td class="whitespace-nowrap px-4 py-3 font-semibold text-zinc-950">
                ${escapeHtml(ticket.code)}
              </td>
              <td class="min-w-56 px-4 py-3 text-sm text-zinc-600">
                <p>${escapeHtml(buyer)}</p>
                ${buyerPhone}
              </td>
              <td class="min-w-56 px-4 py-3 text-sm text-zinc-600">
                <p>${escapeHtml(responsible)}</p>
                ${responsiblePhone}
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <span class="rounded-md px-2 py-1 text-xs font-medium ${statusClass}">
                  ${escapeHtml(statusLabel)}
                </span>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(ticket.paymentMethod ? paymentMethodLabels[ticket.paymentMethod] : "Sin metodo")}
                <p class="mt-1 text-xs text-zinc-400">${escapeHtml(paidAt)}</p>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${entry}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                ${action}
              </td>
            </tr>
          `;
        })
        .join("");
    };

    const loadTickets = async () => {
      const { ticketsUrl } = getConfig();

      if (!ticketsUrl) {
        setStatus("No se encontro la ruta de boletas.", "error");
        return;
      }

      if (!selectedEventId) {
        currentTickets = [];
        renderTickets();
        setStatus("Selecciona un evento para registrar ingreso.");
        return;
      }

      setStatus("Cargando boletas.");

      try {
        const url = `${ticketsUrl}?eventId=${encodeURIComponent(selectedEventId)}`;
        const payload = await requestJson<unknown[]>(url);
        currentTickets = Array.isArray(payload) ? payload.filter(isTicketRecord) : [];
        renderTickets();
        setStatus("Boletas actualizadas.", "success");
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible cargar boletas.",
          "error"
        );
      }
    };

    const loadEvents = async () => {
      const { eventsUrl } = getConfig();

      if (!eventsUrl) {
        setStatus("No se encontro la ruta de eventos.", "error");
        return;
      }

      setStatus("Cargando eventos.");

      try {
        const payload = await requestJson<unknown[]>(eventsUrl);
        currentEvents = Array.isArray(payload) ? payload.filter(isEventRecord) : [];
        renderEventOptions();

        if (selectedEventId) {
          await loadTickets();
        } else {
          currentTickets = [];
          renderTickets();
          setStatus("No hay eventos para consultar.");
        }
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible cargar eventos.",
          "error"
        );
      }
    };

    const checkInTicket = async (ticketId: string) => {
      const { ticketsUrl } = getConfig();
      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticketsUrl || !ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      if (ticket.status !== "paid") {
        setStatus("La boleta debe estar pagada antes de registrar ingreso.", "error");
        return;
      }

      setStatus(`Registrando ingreso de ${ticket.code}.`);

      try {
        const updated = await requestJson<TicketRecord>(
          `${ticketsUrl}/${encodeURIComponent(ticket.id)}/check-in`,
          {
            body: JSON.stringify({
              checkedInBy: currentUser?.name ?? "Porteria"
            }),
            method: "PATCH"
          }
        );

        if (!isTicketRecord(updated)) {
          throw new Error("La API no devolvio una boleta valida.");
        }

        currentTickets = currentTickets.map((item) =>
          item.id === updated.id ? updated : item
        );
        renderTickets();
        setStatus(`Ingreso registrado para ${updated.code}.`, "success");
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible registrar ingreso.",
          "error"
        );
      }
    };

    const bindCheckInActions = () => {
      document.querySelector("[data-refresh-checkin]")?.addEventListener("click", () => {
        void loadEvents();
      });

      document
        .querySelector<HTMLSelectElement>("[data-event-selector]")
        ?.addEventListener("change", (event) => {
          const target = event.currentTarget as HTMLSelectElement;
          updateSelectedEvent(target.value);
          void loadTickets();
        });

      document
        .querySelector<HTMLInputElement>("[data-checkin-search]")
        ?.addEventListener("input", () => {
          renderTickets();
        });

      document.querySelector("[data-clear-checkin-search]")?.addEventListener("click", () => {
        const input = document.querySelector<HTMLInputElement>("[data-checkin-search]");

        if (input) {
          input.value = "";
        }

        renderTickets();
      });

      document.querySelector("[data-checkin-body]")?.addEventListener("click", (event) => {
        const target = event.target;

        if (!(target instanceof HTMLElement)) {
          return;
        }

        const button = target.closest<HTMLButtonElement>("[data-check-in-ticket]");

        if (!button?.dataset.checkInTicket) {
          return;
        }

        void checkInTicket(button.dataset.checkInTicket);
      });
    };

    try {
      const { authMeUrl } = getConfig();
      const token = sessionStorage.getItem("boletas.auth.token");
      const expiresAt = sessionStorage.getItem("boletas.auth.expiresAt");
      const user = readStoredUser();

      if (!authMeUrl || !token || isExpired(expiresAt) || !user) {
        redirectToLogin();
      } else {
        authToken = token;

        whenReady(() => {
          renderUser(user);
          bindLogout();
          bindCheckInActions();
        });

        validateSession(authMeUrl, token)
          .then((apiUser) => {
            sessionStorage.setItem("boletas.auth.user", JSON.stringify(apiUser));
            renderUser(apiUser);
            renderAdminOnly(apiUser);
            void loadEvents();
          })
          .catch(() => {
            redirectToLogin();
          });
      }
    } catch {
      redirectToLogin();
    }
  </script>

  <div class="grid min-h-screen lg:grid-cols-[240px_1fr]">
    <aside class="border-b border-zinc-200 bg-white px-4 py-4 lg:border-b-0 lg:border-r">
      <div class="flex h-full flex-col gap-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-950 text-white">
            <Ticket size={20} />
          </span>
          <div>
            <p class="text-sm font-semibold text-zinc-950">Boletas</p>
            <p class="text-xs text-zinc-500">Entrada</p>
          </div>
        </div>

        <nav class="grid gap-1 text-sm">
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/dashboard">
            Tablero
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-admin-only href="/users">
            Usuarios
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/events">
            Eventos
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/tickets">
            Boletas
          </a>
          <a class="rounded-md bg-zinc-950 px-3 py-2 font-medium text-white" href="/check-in">
            Entrada
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-manager-only href="/payments">
            Pagos
          </a>
        </nav>

        <div class="mt-auto rounded-lg border border-zinc-200 bg-zinc-50 p-3">
          <p class="text-xs font-medium text-zinc-500">Sesion</p>
          <p class="mt-1 truncate text-sm font-semibold text-zinc-950" data-auth-user-name>
            Usuario
          </p>
          <p class="mt-1 truncate text-xs text-zinc-500" data-auth-user-email>
            usuario@dominio.com
          </p>
        </div>
      </div>
    </aside>

    <main class="min-w-0">
      <header class="border-b border-zinc-200 bg-white px-4 py-4 sm:px-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <div class="flex items-center gap-2 text-xs font-medium text-zinc-500">
              <CalendarDays size={14} />
              <span>Control de ingreso</span>
            </div>
            <h1 class="mt-2 text-2xl font-semibold text-zinc-950">
              Entrada
            </h1>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <select
              class="h-10 min-w-64 rounded-md border border-zinc-200 bg-white px-3 text-sm text-zinc-700 outline-none focus:border-zinc-500 disabled:bg-zinc-100"
              data-event-selector
            >
              <option value="">Cargando eventos</option>
            </select>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-refresh-checkin
              title="Actualizar"
              type="button"
            >
              <RefreshCw size={17} />
              Actualizar
            </button>
            <div class="flex h-10 items-center gap-2 rounded-md border border-zinc-200 bg-white px-3">
              <ShieldCheck class="text-emerald-600" size={17} />
              <div class="hidden leading-tight sm:block">
                <p class="max-w-36 truncate text-xs font-semibold text-zinc-950" data-auth-user-name>
                  Usuario
                </p>
                <p class="text-[11px] uppercase text-zinc-500" data-auth-user-role>
                  Admin
                </p>
              </div>
            </div>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-logout-button
              title="Cerrar sesion"
              type="button"
            >
              <LogOut size={17} />
              Salir
            </button>
          </div>
        </div>
      </header>

      <div class="space-y-6 p-4 sm:p-6">
        <p class="hidden rounded-md border px-3 py-2 text-sm" data-checkin-status></p>

        <section class="grid gap-4 md:grid-cols-4">
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Boletas</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-checkin-total>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Por ingresar</p>
            <p class="mt-2 text-2xl font-semibold text-emerald-700" data-checkin-ready>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Ingresadas</p>
            <p class="mt-2 text-2xl font-semibold text-indigo-700" data-checkin-used>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">No permitidas</p>
            <p class="mt-2 text-2xl font-semibold text-rose-700" data-checkin-blocked>0</p>
          </div>
        </section>

        <section class="grid gap-6 xl:grid-cols-[320px_1fr]">
          <section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-emerald-600 text-white">
                <ScanLine size={18} />
              </span>
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Validar entrada</h2>
                <p class="mt-1 text-xs text-zinc-500" data-checkin-event-name>Selecciona un evento</p>
              </div>
            </div>

            <label class="mt-5 grid gap-2">
              <span class="text-sm font-medium text-zinc-700">Busqueda</span>
              <span class="relative block">
                <Search class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400" size={16} />
                <input
                  class="h-10 w-full rounded-md border border-zinc-200 bg-white pl-9 pr-3 text-sm text-zinc-950 outline-none focus:border-zinc-500"
                  data-checkin-search
                  placeholder="Codigo, comprador o responsable"
                  type="search"
                />
              </span>
            </label>

            <button
              class="mt-3 inline-flex h-10 w-full items-center justify-center rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-clear-checkin-search
              type="button"
            >
              Limpiar busqueda
            </button>

            <div class="mt-5 rounded-md border border-zinc-100 bg-zinc-50 px-3 py-3">
              <div class="flex items-center gap-3">
                <UserRoundCheck class="text-emerald-600" size={18} />
                <div>
                  <p class="text-sm font-semibold text-zinc-950">Registra quien ingresa</p>
                  <p class="mt-1 text-xs text-zinc-500" data-auth-user-name>Usuario</p>
                </div>
              </div>
            </div>
          </section>

          <section class="rounded-lg border border-zinc-200 bg-white shadow-sm">
            <div class="flex flex-col gap-3 border-b border-zinc-200 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Ingreso</h2>
                <p class="mt-1 text-xs text-zinc-500">Boletas del evento seleccionado</p>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-zinc-100 text-left">
                <thead class="bg-zinc-50 text-xs uppercase text-zinc-500">
                  <tr>
                    <th class="px-4 py-3 font-medium">Codigo</th>
                    <th class="px-4 py-3 font-medium">Titular</th>
                    <th class="px-4 py-3 font-medium">Responsable</th>
                    <th class="px-4 py-3 font-medium">Estado</th>
                    <th class="px-4 py-3 font-medium">Pago</th>
                    <th class="px-4 py-3 font-medium">Ingreso</th>
                    <th class="px-4 py-3 text-right font-medium">Accion</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 bg-white" data-checkin-body>
                  <tr>
                    <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="7">
                      Cargando boletas
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
