---
import {
  ArrowRight,
  BarChart3,
  CheckCircle2,
  ClipboardCheck,
  LockKeyhole,
  ScanLine,
  ShieldCheck,
  Ticket,
  WalletCards
} from "lucide-astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const capabilities = [
  {
    icon: Ticket,
    label: "Inventario claro",
    text: "Controla lotes, estados, responsables y disponibilidad sin mezclar hojas sueltas."
  },
  {
    icon: WalletCards,
    label: "Pagos con evidencia",
    text: "Registra transferencia, efectivo, capitalizacion y validacion antes del ingreso."
  },
  {
    icon: ScanLine,
    label: "Entrada el dia del evento",
    text: "Consulta quien pago, quien esta bloqueado y que boleta ya fue usada."
  }
] as const;

const checkpoints = [
  "Asignacion de boletas por responsable",
  "Recaudo validado y pendiente",
  "Evidencias protegidas",
  "Corte operativo del evento"
];
---

<BaseLayout title="Boletas | Gestion de eventos">
  <main class="min-h-screen bg-zinc-950 text-white">
    <section class="relative isolate flex min-h-[88svh] overflow-hidden">
      <canvas
        aria-hidden="true"
        class="absolute inset-0 h-full w-full"
        data-hero-canvas
      ></canvas>
      <div class="absolute inset-0 bg-black/45"></div>

      <nav class="absolute left-0 right-0 top-0 z-20 mx-auto flex max-w-7xl items-center justify-between px-5 py-5 sm:px-8">
        <a class="inline-flex items-center gap-3 text-white" href="/">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-white text-zinc-950">
            <Ticket size={20} />
          </span>
          <span class="text-sm font-semibold uppercase tracking-[0.18em]">Boletas</span>
        </a>
        <a
          class="inline-flex h-10 items-center gap-2 rounded-md bg-white px-4 text-sm font-semibold text-zinc-950 hover:bg-emerald-100"
          href="/login"
        >
          <LockKeyhole size={16} />
          Iniciar sesion
        </a>
      </nav>

      <div class="relative z-10 mx-auto flex w-full max-w-7xl items-end px-5 pb-14 pt-28 sm:px-8 lg:pb-20">
        <div class="max-w-3xl">
          <p class="mb-5 inline-flex items-center gap-2 rounded-md bg-white/12 px-3 py-2 text-sm font-medium text-emerald-100 ring-1 ring-white/20 backdrop-blur">
            <ShieldCheck size={16} />
            Control operativo para eventos con venta fisica y transferencias
          </p>
          <h1 class="text-5xl font-semibold leading-none text-white sm:text-6xl lg:text-7xl">
            Boletas
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-100 sm:text-xl">
            Gestiona asignaciones, ventas, evidencias de pago, capitalizacion y entrada del evento desde una sola operacion.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              class="inline-flex h-12 items-center gap-2 rounded-md bg-emerald-400 px-5 text-sm font-semibold text-zinc-950 hover:bg-emerald-300"
              href="/login"
            >
              Entrar al sistema
              <ArrowRight size={18} />
            </a>
            <a
              class="inline-flex h-12 items-center rounded-md border border-white/35 px-5 text-sm font-semibold text-white hover:bg-white/10"
              href="#operacion"
            >
              Ver alcance
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="operacion" class="bg-zinc-50 px-5 py-12 text-zinc-950 sm:px-8 lg:py-16">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-emerald-700">Operacion del evento</p>
          <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Del inventario al ingreso, sin perder el rastro.</h2>
          <p class="mt-4 text-base leading-7 text-zinc-600">
            La app esta pensada para equipos que distribuyen boletas, reciben pagos por transferencia o efectivo y necesitan llegar al dia del evento con datos claros.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {
            capabilities.map(({ icon: Icon, label, text }) => (
              <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-zinc-950 text-white">
                  <Icon size={18} />
                </span>
                <h3 class="mt-5 text-base font-semibold">{label}</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-600">{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white px-5 py-12 text-zinc-950 sm:px-8 lg:py-16">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1fr_420px] lg:items-center">
        <div class="grid gap-3 sm:grid-cols-2">
          {
            checkpoints.map((item) => (
              <div class="flex items-center gap-3 rounded-lg border border-zinc-200 bg-zinc-50 p-4">
                <CheckCircle2 class="shrink-0 text-emerald-600" size={20} />
                <span class="text-sm font-medium text-zinc-800">{item}</span>
              </div>
            ))
          }
        </div>

        <div class="rounded-lg border border-zinc-200 bg-zinc-950 p-6 text-white shadow-sm">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm text-zinc-400">Tablero demo</p>
              <p class="mt-1 text-2xl font-semibold">$270.000</p>
            </div>
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-md bg-emerald-400 text-zinc-950">
              <BarChart3 size={22} />
            </span>
          </div>
          <div class="mt-6 grid gap-3">
            <div class="flex items-center justify-between rounded-md bg-white/10 px-3 py-3">
              <span class="inline-flex items-center gap-2 text-sm text-zinc-200">
                <ClipboardCheck size={16} />
                Ventas pendientes
              </span>
              <strong>1</strong>
            </div>
            <div class="flex items-center justify-between rounded-md bg-white/10 px-3 py-3">
              <span class="inline-flex items-center gap-2 text-sm text-zinc-200">
                <ScanLine size={16} />
                Ingresos usados
              </span>
              <strong>1 / 120</strong>
            </div>
          </div>
          <a
            class="mt-6 inline-flex h-11 w-full items-center justify-center gap-2 rounded-md bg-white text-sm font-semibold text-zinc-950 hover:bg-emerald-100"
            href="/login"
          >
            Acceder con usuario
            <ArrowRight size={17} />
          </a>
        </div>
      </div>
    </section>
  </main>

  <script>
    const canvas = document.querySelector<HTMLCanvasElement>("[data-hero-canvas]");

    if (canvas) {
      const context = canvas.getContext("2d");
      const colors = ["#34d399", "#fbbf24", "#fb7185", "#e5e7eb"];
      const tickets = Array.from({ length: 34 }, (_, index) => ({
        color: colors[index % colors.length],
        phase: Math.random() * Math.PI * 2,
        speed: 0.18 + Math.random() * 0.22,
        x: Math.random(),
        y: Math.random()
      }));

      const resize = () => {
        const ratio = window.devicePixelRatio || 1;
        canvas.width = Math.floor(canvas.clientWidth * ratio);
        canvas.height = Math.floor(canvas.clientHeight * ratio);
        context?.setTransform(ratio, 0, 0, ratio, 0, 0);
      };

      const drawTicket = (
        x: number,
        y: number,
        width: number,
        height: number,
        color: string,
        angle: number
      ) => {
        if (!context) {
          return;
        }

        context.save();
        context.translate(x, y);
        context.rotate(angle);
        context.fillStyle = color;
        context.globalAlpha = 0.86;
        context.fillRect(-width / 2, -height / 2, width, height);
        context.globalAlpha = 0.28;
        context.fillStyle = "#111827";
        context.fillRect(-width / 2 + 12, -height / 2 + 10, width - 24, 5);
        context.fillRect(-width / 2 + 12, height / 2 - 14, width * 0.48, 4);
        context.restore();
      };

      const draw = (time: number) => {
        if (!context) {
          return;
        }

        const width = canvas.clientWidth;
        const height = canvas.clientHeight;
        context.clearRect(0, 0, width, height);
        context.fillStyle = "#09090b";
        context.fillRect(0, 0, width, height);

        context.strokeStyle = "rgba(255,255,255,0.1)";
        context.lineWidth = 1;
        for (let x = 0; x < width; x += 72) {
          context.beginPath();
          context.moveTo(x, 0);
          context.lineTo(x + width * 0.18, height);
          context.stroke();
        }

        tickets.forEach((ticket, index) => {
          const drift = Math.sin(time * 0.001 * ticket.speed + ticket.phase);
          const x = ((ticket.x * width + time * 0.018 * ticket.speed) % (width + 160)) - 80;
          const y = ticket.y * height + drift * 26;
          const size = index % 3 === 0 ? 92 : 70;
          drawTicket(x, y, size, 34, ticket.color, drift * 0.18);
        });

        context.fillStyle = "rgba(255,255,255,0.12)";
        for (let i = 0; i < 110; i += 1) {
          const x = (i * 67 + time * 0.014) % width;
          const y = (i * 43) % height;
          context.beginPath();
          context.arc(x, y, i % 4 === 0 ? 2.2 : 1.3, 0, Math.PI * 2);
          context.fill();
        }

        requestAnimationFrame(draw);
      };

      resize();
      window.addEventListener("resize", resize);
      requestAnimationFrame(draw);
    }
  </script>
</BaseLayout>
