---
import {
  Bell,
  CalendarDays,
  CircleDollarSign,
  ClipboardCheck,
  Filter,
  LogOut,
  Plus,
  ScanLine,
  Search,
  ShieldCheck,
  Ticket,
  Upload,
  UserRoundCheck,
  WalletCards
} from "lucide-astro";
import DistributionList from "../components/DistributionList.astro";
import MetricCard from "../components/MetricCard.astro";
import PaymentEvidenceList from "../components/PaymentEvidenceList.astro";
import TicketTable from "../components/TicketTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import type {
  EvidenceStatus,
  PaymentMethod,
  PublicEventDashboard,
  TicketStatus
} from "@boletas/shared";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? "/api";
const publicDashboardUrl = `${apiBase}/public/events/evt_demo/dashboard`;
const authMeUrl = `${apiBase}/auth/me`;

const fallbackDashboard: PublicEventDashboard = {
  event: {
    date: "2026-07-18T20:00:00.000Z",
    expectedAttendees: 120,
    name: "Lanzamiento Demo",
    venue: "Auditorio Principal"
  },
  totals: {
    available: 1,
    assigned: 1,
    capitalization: 45000,
    grossSales: 270000,
    paid: 3,
    pendingToCollect: 90000,
    sold: 4,
    tickets: 7,
    used: 1,
    void: 1
  },
  distributors: [
    {
      assignedTickets: 3,
      grossSales: 180000,
      label: "Responsable 1",
      paidTickets: 2,
      usedTickets: 0
    },
    {
      assignedTickets: 1,
      grossSales: 0,
      label: "Responsable 2",
      paidTickets: 0,
      usedTickets: 0
    },
    {
      assignedTickets: 1,
      grossSales: 90000,
      label: "Responsable 3",
      paidTickets: 1,
      usedTickets: 1
    }
  ],
  recentPayments: [
    {
      amount: 90000,
      label: "Evidencia 1",
      method: "transfer",
      status: "pending"
    },
    {
      amount: 90000,
      label: "Evidencia 2",
      method: "cash",
      status: "approved"
    }
  ],
  ticketSamples: [
    {
      amount: 90000,
      detail: "Pago validado",
      distributorLabel: "Responsable 1",
      reference: "Boleta 1",
      status: "paid"
    },
    {
      amount: 90000,
      detail: "Asignada a responsable",
      distributorLabel: "Responsable 1",
      reference: "Boleta 2",
      status: "assigned"
    },
    {
      amount: 90000,
      detail: "Pago pendiente de validar",
      distributorLabel: "Responsable 2",
      reference: "Boleta 3",
      status: "sold"
    },
    {
      amount: 90000,
      detail: "Ingreso registrado",
      distributorLabel: "Responsable 3",
      reference: "Boleta 4",
      status: "used"
    },
    {
      amount: 90000,
      detail: "Disponible para asignar",
      distributorLabel: "Sin asignar",
      reference: "Boleta 5",
      status: "available"
    }
  ]
};

const dashboard = fallbackDashboard;

const money = new Intl.NumberFormat("es-CO", {
  currency: "COP",
  maximumFractionDigits: 0,
  style: "currency"
});

const eventDate = new Intl.DateTimeFormat("es-CO", {
  day: "2-digit",
  month: "short",
  year: "numeric"
}).format(new Date(dashboard.event.date));

const ticketStatusLabels: Record<TicketStatus, "Disponible" | "Asignada" | "Reservada" | "Vendida" | "Pagada" | "Usada" | "Bloqueada"> = {
  assigned: "Asignada",
  available: "Disponible",
  paid: "Pagada",
  reserved: "Reservada",
  sold: "Vendida",
  used: "Usada",
  void: "Bloqueada"
};

const evidenceStatusLabels: Record<EvidenceStatus, "Aprobado" | "Pendiente" | "Rechazado"> = {
  approved: "Aprobado",
  pending: "Pendiente",
  rejected: "Rechazado"
};

const paymentMethodLabels: Record<PaymentMethod, string> = {
  cash: "Efectivo",
  transfer: "Transferencia"
};

const pendingValidation = Math.max(dashboard.totals.sold - dashboard.totals.paid, 0);

const metrics = [
  {
    label: "Recaudo validado",
    value: money.format(dashboard.totals.grossSales),
    detail: `${dashboard.totals.paid} boletas pagadas`,
    detailField: "metric-gross-detail",
    tone: "emerald",
    valueField: "metric-gross-value",
    icon: CircleDollarSign
  },
  {
    label: "Por validar",
    value: money.format(dashboard.totals.pendingToCollect),
    detail: `${pendingValidation} ventas pendientes`,
    detailField: "metric-pending-detail",
    tone: "amber",
    valueField: "metric-pending-value",
    icon: Upload
  },
  {
    label: "Capitalizacion",
    value: money.format(dashboard.totals.capitalization),
    detail: "Meta interna del evento",
    detailField: "metric-capitalization-detail",
    tone: "zinc",
    valueField: "metric-capitalization-value",
    icon: WalletCards
  },
  {
    label: "Ingreso",
    value: `${dashboard.totals.used} / ${dashboard.event.expectedAttendees}`,
    detail: "Usadas el dia del evento",
    detailField: "metric-entry-detail",
    tone: "rose",
    valueField: "metric-entry-value",
    icon: UserRoundCheck
  }
] as const;

const distributors = dashboard.distributors.map((distributor) => ({
  amount: money.format(distributor.grossSales),
  name: distributor.label,
  paid: distributor.paidTickets,
  tickets: distributor.assignedTickets,
  used: distributor.usedTickets
}));

const evidenceRows = dashboard.recentPayments.map((payment) => ({
  amount: money.format(payment.amount),
  label: payment.label,
  method: paymentMethodLabels[payment.method],
  status: evidenceStatusLabels[payment.status]
}));

const tickets = dashboard.ticketSamples.map((ticket) => ({
  amount: money.format(ticket.amount),
  detail: ticket.detail,
  distributor: ticket.distributorLabel,
  reference: ticket.reference,
  status: ticketStatusLabels[ticket.status]
}));

---

<BaseLayout title="Boletas | Control de evento">
  <span hidden data-auth-me-url={authMeUrl}></span>
  <script>
    interface StoredUser {
      id: string;
      email: string;
      name: string;
      role: "admin" | "seller" | "gate";
    }

    interface AuthMeResponse {
      user?: StoredUser;
    }

    const allowedRoles = new Set(["admin", "seller", "gate"]);

    const clearSession = () => {
      sessionStorage.removeItem("boletas.auth.token");
      sessionStorage.removeItem("boletas.auth.expiresAt");
      sessionStorage.removeItem("boletas.auth.user");
    };

    const redirectToLogin = () => {
      clearSession();
      window.location.replace("/login");
    };

    const getAuthMeUrl = () => {
      const config = document.querySelector<HTMLElement>("[data-auth-me-url]");

      return config?.dataset.authMeUrl ?? null;
    };

    const isStoredUser = (value: unknown): value is StoredUser => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const user = value as Partial<StoredUser>;

      return (
        typeof user.id === "string" &&
        typeof user.email === "string" &&
        typeof user.name === "string" &&
        typeof user.role === "string" &&
        allowedRoles.has(user.role)
      );
    };

    const readStoredUser = (): StoredUser | null => {
      const storedUser = sessionStorage.getItem("boletas.auth.user");

      if (!storedUser) {
        return null;
      }

      try {
        const parsed = JSON.parse(storedUser) as unknown;

        if (!isStoredUser(parsed)) {
          return null;
        }

        return parsed;
      } catch {
        return null;
      }
    };

    const isExpired = (expiresAt: string | null) => {
      const expiresAtMs = expiresAt ? Date.parse(expiresAt) : Number.NaN;

      return !Number.isFinite(expiresAtMs) || expiresAtMs <= Date.now();
    };

    const renderUser = (user: StoredUser) => {
      document.querySelectorAll("[data-auth-user-name]").forEach((element) => {
        element.textContent = user.name;
      });

      document.querySelectorAll("[data-auth-user-email]").forEach((element) => {
        element.textContent = user.email;
      });

      document.querySelectorAll("[data-auth-user-role]").forEach((element) => {
        element.textContent = user.role;
      });
    };

    const bindLogout = () => {
      document.querySelectorAll("[data-logout-button]").forEach((button) => {
        button.addEventListener("click", () => {
          clearSession();
          window.location.replace("/login");
        });
      });
    };

    const whenReady = (callback: () => void) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", callback, { once: true });
      } else {
        callback();
      }
    };

    const validateSession = async (url: string, token: string) => {
      const response = await fetch(url, {
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error(`Auth session rejected with ${response.status}`);
      }

      const payload = (await response.json()) as AuthMeResponse;

      if (!isStoredUser(payload.user)) {
        throw new Error("Auth session response did not include a valid user.");
      }

      return payload.user;
    };

    try {
      const authUrl = getAuthMeUrl();
      const token = sessionStorage.getItem("boletas.auth.token");
      const expiresAt = sessionStorage.getItem("boletas.auth.expiresAt");
      const user = readStoredUser();

      if (!authUrl || !token || isExpired(expiresAt) || !user) {
        redirectToLogin();
      } else {
        let activeUser = user;

        whenReady(() => {
          renderUser(activeUser);
          bindLogout();
        });

        validateSession(authUrl, token)
          .then((apiUser) => {
            activeUser = apiUser;
            sessionStorage.setItem("boletas.auth.user", JSON.stringify(apiUser));
            renderUser(activeUser);
          })
          .catch(() => {
            redirectToLogin();
          });
      }
    } catch {
      redirectToLogin();
    }
  </script>

  <div class="grid min-h-screen lg:grid-cols-[240px_1fr]" data-dashboard-root data-dashboard-url={publicDashboardUrl}>
    <aside class="border-b border-zinc-200 bg-white px-4 py-4 lg:border-b-0 lg:border-r">
      <div class="flex h-full flex-col gap-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-950 text-white">
            <Ticket size={20} />
          </span>
          <div>
            <p class="text-sm font-semibold text-zinc-950">Boletas</p>
            <p class="text-xs text-zinc-500">Evento activo</p>
          </div>
        </div>

        <nav class="grid gap-1 text-sm">
          <a class="rounded-md bg-zinc-950 px-3 py-2 font-medium text-white" href="/dashboard">
            Tablero
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href={publicDashboardUrl}>
            Eventos
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="#">
            Boletas
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="#">
            Pagos
          </a>
        </nav>

        <div class="mt-auto rounded-lg border border-zinc-200 bg-zinc-50 p-3">
          <p class="text-xs font-medium text-zinc-500">Sesion</p>
          <p class="mt-1 truncate text-sm font-semibold text-zinc-950" data-auth-user-name>
            Usuario
          </p>
          <p class="mt-1 truncate text-xs text-zinc-500" data-auth-user-email>
            usuario@dominio.com
          </p>
        </div>
      </div>
    </aside>

    <main class="min-w-0">
      <header class="border-b border-zinc-200 bg-white px-4 py-4 sm:px-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <div class="flex items-center gap-2 text-xs font-medium text-zinc-500">
              <CalendarDays size={14} />
              <span data-dashboard-field="event-summary">{eventDate} - {dashboard.event.venue}</span>
            </div>
            <h1 class="mt-2 text-2xl font-semibold text-zinc-950" data-dashboard-field="event-name">
              {dashboard.event.name}
            </h1>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <label class="relative block">
              <Search class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400" size={16} />
              <input
                class="h-10 w-64 rounded-md border border-zinc-200 bg-white pl-9 pr-3 text-sm text-zinc-950 outline-none focus:border-zinc-400"
                placeholder="Buscar referencia"
                type="search"
              />
            </label>
            <button class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-zinc-200 text-zinc-600 hover:bg-zinc-50" title="Filtrar">
              <Filter size={18} />
            </button>
            <button class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-zinc-200 text-zinc-600 hover:bg-zinc-50" title="Alertas">
              <Bell size={18} />
            </button>
            <button class="inline-flex h-10 items-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-medium text-white hover:bg-zinc-800">
              <Plus size={18} />
              Boleta
            </button>
            <div class="flex h-10 items-center gap-2 rounded-md border border-zinc-200 bg-white px-3">
              <ShieldCheck class="text-emerald-600" size={17} />
              <div class="hidden leading-tight sm:block">
                <p class="max-w-36 truncate text-xs font-semibold text-zinc-950" data-auth-user-name>
                  Usuario
                </p>
                <p class="text-[11px] uppercase text-zinc-500" data-auth-user-role>
                  admin
                </p>
              </div>
            </div>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-logout-button
              title="Cerrar sesion"
              type="button"
            >
              <LogOut size={17} />
              Salir
            </button>
          </div>
        </div>
      </header>

      <div class="space-y-6 p-4 sm:p-6">
        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {
            metrics.map((metric) => (
              <MetricCard
                detail={metric.detail}
                icon={metric.icon}
                label={metric.label}
                tone={metric.tone}
                value={metric.value}
                detailField={metric.detailField}
                valueField={metric.valueField}
              />
            ))
          }
        </section>

        <section class="grid gap-6 xl:grid-cols-[1fr_360px]">
          <div data-dashboard-section="tickets">
            <TicketTable rows={tickets} />
          </div>

          <div class="space-y-6">
            <section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <h2 class="text-sm font-semibold text-zinc-950">Entrada</h2>
                  <p class="mt-1 text-xs text-zinc-500">Validacion de boleta pagada</p>
                </div>
                <button class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-emerald-600 text-white hover:bg-emerald-700" title="Escanear">
                  <ScanLine size={18} />
                </button>
              </div>
              <div class="mt-4 grid grid-cols-2 divide-x divide-zinc-100 border-t border-zinc-100 pt-4">
                <div class="pr-3">
                  <p class="text-xs font-medium text-emerald-700">Permitidas</p>
                  <p class="mt-2 text-2xl font-semibold text-emerald-950" data-dashboard-field="entry-allowed">{dashboard.totals.paid}</p>
                </div>
                <div class="pl-3">
                  <p class="text-xs font-medium text-rose-700">Bloqueadas</p>
                  <p class="mt-2 text-2xl font-semibold text-rose-950" data-dashboard-field="entry-blocked">{dashboard.totals.void}</p>
                </div>
              </div>
            </section>

            <section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
              <div class="flex items-center gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-amber-50 text-amber-700">
                  <ClipboardCheck size={18} />
                </span>
                <div>
                  <h2 class="text-sm font-semibold text-zinc-950">Corte rapido</h2>
                  <p class="mt-1 text-xs text-zinc-500" data-dashboard-field="pending-validation">{pendingValidation} ventas pendientes de validar</p>
                </div>
              </div>
              <button class="mt-4 h-10 w-full rounded-md border border-zinc-200 text-sm font-medium text-zinc-700 hover:bg-zinc-50">
                Cerrar corte
              </button>
            </section>
          </div>
        </section>

        <section class="grid gap-6 xl:grid-cols-[1fr_360px]">
          <div data-dashboard-section="distribution">
            <DistributionList rows={distributors} />
          </div>
          <div data-dashboard-section="evidence">
            <PaymentEvidenceList rows={evidenceRows} />
          </div>
        </section>
      </div>
    </main>
  </div>

  <script>
    const initDashboardRefresh = () => {
      type RuntimeTicketStatus = "assigned" | "available" | "paid" | "reserved" | "sold" | "used" | "void";
      type RuntimeTicketLabel = "Disponible" | "Asignada" | "Reservada" | "Vendida" | "Pagada" | "Usada" | "Bloqueada";
      type RuntimeEvidenceStatus = "approved" | "pending" | "rejected";
      type RuntimeEvidenceLabel = "Aprobado" | "Pendiente" | "Rechazado";
      type RuntimePaymentMethod = "cash" | "transfer";

      interface RuntimePublicDashboard {
        event: {
          date: string;
          expectedAttendees: number;
          name: string;
          venue: string;
        };
        totals: {
          available: number;
          assigned: number;
          capitalization: number;
          grossSales: number;
          paid: number;
          pendingToCollect: number;
          sold: number;
          tickets: number;
          used: number;
          void: number;
        };
        distributors: Array<{
          label: string;
          assignedTickets: number;
          paidTickets: number;
          usedTickets: number;
          grossSales: number;
        }>;
        ticketSamples: Array<{
          reference: string;
          status: RuntimeTicketStatus;
          amount: number;
          detail: string;
          distributorLabel: string;
        }>;
        recentPayments: Array<{
          label: string;
          method: RuntimePaymentMethod;
          amount: number;
          status: RuntimeEvidenceStatus;
        }>;
      }

      const root = document.querySelector<HTMLElement>("[data-dashboard-root]");
      const dashboardUrl = root?.getAttribute("data-dashboard-url");

      if (!dashboardUrl) {
        return;
      }

      const money = new Intl.NumberFormat("es-CO", {
        currency: "COP",
        maximumFractionDigits: 0,
        style: "currency"
      });

      const dateFormatter = new Intl.DateTimeFormat("es-CO", {
        day: "2-digit",
        month: "short",
        year: "numeric"
      });

      const ticketStatusLabels: Record<RuntimeTicketStatus, RuntimeTicketLabel> = {
        assigned: "Asignada",
        available: "Disponible",
        paid: "Pagada",
        reserved: "Reservada",
        sold: "Vendida",
        used: "Usada",
        void: "Bloqueada"
      };

      const ticketStatusClasses: Record<RuntimeTicketLabel, string> = {
        Asignada: "bg-zinc-100 text-zinc-700",
        Bloqueada: "bg-rose-50 text-rose-700",
        Disponible: "bg-sky-50 text-sky-700",
        Pagada: "bg-emerald-50 text-emerald-700",
        Reservada: "bg-violet-50 text-violet-700",
        Usada: "bg-indigo-50 text-indigo-700",
        Vendida: "bg-amber-50 text-amber-700"
      };

      const evidenceStatusLabels: Record<RuntimeEvidenceStatus, RuntimeEvidenceLabel> = {
        approved: "Aprobado",
        pending: "Pendiente",
        rejected: "Rechazado"
      };

      const evidenceStatusClasses: Record<RuntimeEvidenceLabel, string> = {
        Aprobado: "bg-emerald-50 text-emerald-700 ring-emerald-200",
        Pendiente: "bg-amber-50 text-amber-700 ring-amber-200",
        Rechazado: "bg-rose-50 text-rose-700 ring-rose-200"
      };

      const paymentMethodLabels: Record<RuntimePaymentMethod, string> = {
        cash: "Efectivo",
        transfer: "Transferencia"
      };

      const escapeHtml = (value: unknown) =>
        String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");

      const setText = (field: string, value: unknown) => {
        const element = document.querySelector(`[data-dashboard-field="${field}"]`);

        if (element) {
          element.textContent = String(value);
        }
      };

      const setSection = (section: string, html: string) => {
        const element = document.querySelector(`[data-dashboard-section="${section}"]`);

        if (element) {
          element.innerHTML = html;
        }
      };

      const renderTickets = (dashboard: RuntimePublicDashboard) => {
        const rows = Array.isArray(dashboard.ticketSamples) ? dashboard.ticketSamples : [];
        const body = rows.length
          ? rows
              .map((ticket) => {
                const status = ticketStatusLabels[ticket.status] ?? "Disponible";
                const statusClass = ticketStatusClasses[status] ?? ticketStatusClasses.Disponible;

                return `
                  <tr class="hover:bg-zinc-50">
                    <td class="whitespace-nowrap px-4 py-3 font-medium text-zinc-950">${escapeHtml(ticket.reference)}</td>
                    <td class="whitespace-nowrap px-4 py-3 text-zinc-600">${escapeHtml(ticket.detail)}</td>
                    <td class="whitespace-nowrap px-4 py-3 text-zinc-600">${escapeHtml(ticket.distributorLabel)}</td>
                    <td class="whitespace-nowrap px-4 py-3">
                      <span class="rounded-md px-2 py-1 text-xs font-medium ${statusClass}">${escapeHtml(status)}</span>
                    </td>
                    <td class="whitespace-nowrap px-4 py-3 text-right font-semibold text-zinc-950">${escapeHtml(money.format(ticket.amount))}</td>
                  </tr>
                `;
              })
              .join("")
          : `<tr><td class="px-4 py-6 text-center text-sm text-zinc-500" colspan="5">Sin boletas para mostrar</td></tr>`;

        return `
          <section class="rounded-lg border border-zinc-200 bg-white shadow-sm">
            <div class="flex flex-col gap-3 border-b border-zinc-200 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Boletas</h2>
                <p class="mt-1 text-xs text-zinc-500">Estado operativo de inventario</p>
              </div>
              <div class="flex items-center gap-2">
                <button class="h-9 rounded-md border border-zinc-200 px-3 text-xs font-medium text-zinc-700 hover:bg-zinc-50">Filtrar</button>
                <button class="h-9 rounded-md bg-zinc-950 px-3 text-xs font-medium text-white hover:bg-zinc-800">Nueva</button>
              </div>
            </div>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-zinc-100 text-left text-sm">
                <thead class="bg-zinc-50 text-xs uppercase text-zinc-500">
                  <tr>
                    <th class="px-4 py-3 font-medium">Referencia</th>
                    <th class="px-4 py-3 font-medium">Detalle</th>
                    <th class="px-4 py-3 font-medium">Distribuidor</th>
                    <th class="px-4 py-3 font-medium">Estado</th>
                    <th class="px-4 py-3 text-right font-medium">Valor</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 bg-white">${body}</tbody>
              </table>
            </div>
          </section>
        `;
      };

      const renderDistribution = (dashboard: RuntimePublicDashboard) => {
        const rows = Array.isArray(dashboard.distributors) ? dashboard.distributors : [];
        const body = rows.length
          ? rows
              .map(
                (row) => `
                  <div class="grid grid-cols-[1fr_auto] gap-3 py-3">
                    <div>
                      <p class="text-sm font-medium text-zinc-950">${escapeHtml(row.label)}</p>
                      <p class="mt-1 text-xs text-zinc-500">
                        ${escapeHtml(row.assignedTickets)} asignadas - ${escapeHtml(row.paidTickets)} pagadas - ${escapeHtml(row.usedTickets)} usadas
                      </p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-semibold text-zinc-950">${escapeHtml(money.format(row.grossSales))}</p>
                      <p class="mt-1 text-xs text-emerald-700">Recaudado</p>
                    </div>
                  </div>
                `
              )
              .join("")
          : `<div class="py-6 text-sm text-zinc-500">Sin responsables para mostrar</div>`;

        return `
          <section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <div class="flex items-center justify-between gap-3">
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Distribucion</h2>
                <p class="mt-1 text-xs text-zinc-500">Asignacion y recaudo por responsable</p>
              </div>
              <button class="inline-flex h-9 items-center rounded-md border border-zinc-200 px-3 text-xs font-medium text-zinc-700 hover:bg-zinc-50">Ver todo</button>
            </div>
            <div class="mt-4 divide-y divide-zinc-100">${body}</div>
          </section>
        `;
      };

      const renderEvidence = (dashboard: RuntimePublicDashboard) => {
        const rows = Array.isArray(dashboard.recentPayments) ? dashboard.recentPayments : [];
        const body = rows.length
          ? rows
              .map((payment) => {
                const status = evidenceStatusLabels[payment.status] ?? "Pendiente";
                const statusClass = evidenceStatusClasses[status] ?? evidenceStatusClasses.Pendiente;

                return `
                  <article class="py-3 first:pt-0 last:pb-0">
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <p class="text-sm font-medium text-zinc-950">${escapeHtml(payment.label)}</p>
                        <p class="mt-1 text-xs text-zinc-500">${escapeHtml(paymentMethodLabels[payment.method] ?? "Metodo no registrado")}</p>
                      </div>
                      <span class="rounded-md px-2 py-1 text-xs font-medium ring-1 ${statusClass}">${escapeHtml(status)}</span>
                    </div>
                    <p class="mt-3 text-sm font-semibold text-zinc-950">${escapeHtml(money.format(payment.amount))}</p>
                  </article>
                `;
              })
              .join("")
          : `<div class="py-6 text-sm text-zinc-500">Sin evidencias para mostrar</div>`;

        return `
          <section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <div class="flex items-center justify-between gap-3">
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Evidencias</h2>
                <p class="mt-1 text-xs text-zinc-500">Transferencias y efectivo por validar</p>
              </div>
              <button class="inline-flex h-9 items-center rounded-md border border-zinc-200 px-3 text-xs font-medium text-zinc-700 hover:bg-zinc-50">Revisar</button>
            </div>
            <div class="mt-4 divide-y divide-zinc-100">${body}</div>
          </section>
        `;
      };

      const renderDashboard = (dashboard: RuntimePublicDashboard) => {
        const pendingValidation = Math.max((dashboard.totals.sold ?? 0) - (dashboard.totals.paid ?? 0), 0);

        setText("event-summary", `${dateFormatter.format(new Date(dashboard.event.date))} - ${dashboard.event.venue}`);
        setText("event-name", dashboard.event.name);
        setText("metric-gross-value", money.format(dashboard.totals.grossSales));
        setText("metric-gross-detail", `${dashboard.totals.paid} boletas pagadas`);
        setText("metric-pending-value", money.format(dashboard.totals.pendingToCollect));
        setText("metric-pending-detail", `${pendingValidation} ventas pendientes`);
        setText("metric-capitalization-value", money.format(dashboard.totals.capitalization));
        setText("metric-entry-value", `${dashboard.totals.used} / ${dashboard.event.expectedAttendees}`);
        setText("entry-allowed", dashboard.totals.paid);
        setText("entry-blocked", dashboard.totals.void);
        setText("pending-validation", `${pendingValidation} ventas pendientes de validar`);
        setSection("tickets", renderTickets(dashboard));
        setSection("distribution", renderDistribution(dashboard));
        setSection("evidence", renderEvidence(dashboard));
      };

      fetch(dashboardUrl, { headers: { Accept: "application/json" } })
        .then((response) => {
          if (!response.ok) {
            throw new Error(`Dashboard request failed with ${response.status}`);
          }

          return response.json();
        })
        .then((dashboard: RuntimePublicDashboard) => renderDashboard(dashboard))
        .catch(() => {
          root?.setAttribute("data-dashboard-status", "fallback");
        });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initDashboardRefresh, { once: true });
    } else {
      initDashboardRefresh();
    }
  </script>
</BaseLayout>
