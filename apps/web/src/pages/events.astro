---
import {
  CalendarDays,
  LogOut,
  Plus,
  RefreshCw,
  ShieldCheck,
  Ticket
} from "lucide-astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? "/api";
const authMeUrl = `${apiBase}/auth/me`;
const eventsUrl = `${apiBase}/events`;
---

<BaseLayout title="Eventos | Boletas">
  <span hidden data-auth-me-url={authMeUrl} data-events-url={eventsUrl}></span>
  <script>
    type EventStatus = "draft" | "active" | "closed";
    type UserRole = "regular" | "supervisor" | "admin";

    interface StoredUser {
      id: string;
      email: string;
      name: string;
      role: UserRole;
    }

    interface EventRecord {
      id: string;
      name: string;
      date: string;
      venue: string;
      status: EventStatus;
      expectedAttendees: number;
      createdAt: string;
    }

    interface AuthMeResponse {
      user?: StoredUser;
    }

    const allowedRoles = new Set(["regular", "supervisor", "admin"]);
    const allowedEventStatuses = new Set(["draft", "active", "closed"]);
    const roleLabels: Record<UserRole, string> = {
      admin: "Admin",
      regular: "Regular",
      supervisor: "Supervisor"
    };
    const statusLabels: Record<EventStatus, string> = {
      active: "Activo",
      closed: "Cerrado",
      draft: "Borrador"
    };
    const statusClasses: Record<EventStatus, string> = {
      active: "bg-emerald-50 text-emerald-700",
      closed: "bg-zinc-100 text-zinc-600",
      draft: "bg-amber-50 text-amber-700"
    };

    let authToken = "";
    const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);

    const resolveApiUrl = (url: string | null | undefined) => {
      if (!url) {
        return null;
      }

      if (url.startsWith("/api") && localHosts.has(window.location.hostname)) {
        return `http://localhost:3000${url}`;
      }

      return url;
    };

    const clearSession = () => {
      sessionStorage.removeItem("boletas.auth.token");
      sessionStorage.removeItem("boletas.auth.expiresAt");
      sessionStorage.removeItem("boletas.auth.user");
    };

    const redirectToLogin = () => {
      clearSession();
      window.location.replace("/login");
    };

    const getConfig = () => {
      const config = document.querySelector<HTMLElement>("[data-auth-me-url]");

      return {
        authMeUrl: resolveApiUrl(config?.dataset.authMeUrl),
        eventsUrl: resolveApiUrl(config?.dataset.eventsUrl)
      };
    };

    const isStoredUser = (value: unknown): value is StoredUser => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const user = value as Partial<StoredUser>;

      return (
        typeof user.id === "string" &&
        typeof user.email === "string" &&
        typeof user.name === "string" &&
        typeof user.role === "string" &&
        allowedRoles.has(user.role)
      );
    };

    const isEventRecord = (value: unknown): value is EventRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const event = value as Partial<EventRecord>;

      return (
        typeof event.id === "string" &&
        typeof event.name === "string" &&
        typeof event.date === "string" &&
        typeof event.venue === "string" &&
        typeof event.status === "string" &&
        allowedEventStatuses.has(event.status) &&
        typeof event.expectedAttendees === "number" &&
        typeof event.createdAt === "string"
      );
    };

    const readStoredUser = (): StoredUser | null => {
      const storedUser = sessionStorage.getItem("boletas.auth.user");

      if (!storedUser) {
        return null;
      }

      try {
        const parsed = JSON.parse(storedUser) as unknown;

        return isStoredUser(parsed) ? parsed : null;
      } catch {
        return null;
      }
    };

    const isExpired = (expiresAt: string | null) => {
      const expiresAtMs = expiresAt ? Date.parse(expiresAt) : Number.NaN;

      return !Number.isFinite(expiresAtMs) || expiresAtMs <= Date.now();
    };

    const whenReady = (callback: () => void) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", callback, { once: true });
      } else {
        callback();
      }
    };

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");

    const renderUser = (user: StoredUser) => {
      document.querySelectorAll("[data-auth-user-name]").forEach((element) => {
        element.textContent = user.name;
      });

      document.querySelectorAll("[data-auth-user-email]").forEach((element) => {
        element.textContent = user.email;
      });

      document.querySelectorAll("[data-auth-user-role]").forEach((element) => {
        element.textContent = roleLabels[user.role];
      });
    };

    const renderAdminOnly = (user: StoredUser) => {
      document.querySelectorAll<HTMLElement>("[data-admin-only]").forEach((element) => {
        element.classList.toggle("hidden", user.role !== "admin");
      });
    };

    const bindLogout = () => {
      document.querySelectorAll("[data-logout-button]").forEach((button) => {
        button.addEventListener("click", () => {
          clearSession();
          window.location.replace("/login");
        });
      });
    };

    const setStatus = (message: string, tone: "neutral" | "success" | "error" = "neutral") => {
      const element = document.querySelector<HTMLElement>("[data-events-status]");

      if (!element) {
        return;
      }

      const toneClasses = {
        error: "border-rose-200 bg-rose-50 text-rose-700",
        neutral: "border-zinc-200 bg-white text-zinc-600",
        success: "border-emerald-200 bg-emerald-50 text-emerald-700"
      };

      element.className = `rounded-md border px-3 py-2 text-sm ${toneClasses[tone]}`;
      element.textContent = message;
      element.classList.remove("hidden");
    };

    const validateSession = async (url: string, token: string) => {
      const response = await fetch(url, {
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error(`Auth session rejected with ${response.status}`);
      }

      const payload = (await response.json()) as AuthMeResponse;

      if (!isStoredUser(payload.user)) {
        throw new Error("Auth session response did not include a valid user.");
      }

      return payload.user;
    };

    const requestJson = async <T,>(url: string, options: RequestInit = {}) => {
      const response = await fetch(url, {
        ...options,
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${authToken}`,
          ...(options.body ? { "Content-Type": "application/json" } : {}),
          ...options.headers
        }
      });

      if (response.status === 401 || response.status === 403) {
        redirectToLogin();
      }

      if (!response.ok) {
        let message = `Solicitud rechazada con estado ${response.status}.`;

        try {
          const payload = (await response.json()) as { message?: string };

          if (payload.message) {
            message = payload.message;
          }
        } catch {
          // Keep the generic message.
        }

        throw new Error(message);
      }

      return (await response.json()) as T;
    };

    const formatDate = (value: string) => {
      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return "Fecha no registrada";
      }

      return new Intl.DateTimeFormat("es-CO", {
        dateStyle: "medium",
        timeStyle: "short"
      }).format(date);
    };

    const toDateTimeLocal = (value: string) => {
      if (!value) {
        return null;
      }

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return null;
      }

      return date.toISOString();
    };

    const renderEvents = (events: EventRecord[]) => {
      const body = document.querySelector<HTMLElement>("[data-events-body]");
      const count = document.querySelector<HTMLElement>("[data-events-count]");

      if (count) {
        count.textContent = `${events.length}`;
      }

      if (!body) {
        return;
      }

      if (events.length === 0) {
        body.innerHTML = `
          <tr>
            <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="6">
              Sin eventos registrados
            </td>
          </tr>
        `;
        return;
      }

      body.innerHTML = events
        .map((event) => {
          const dashboardUrl = `/dashboard?eventId=${encodeURIComponent(event.id)}`;
          const ticketsUrl = `/tickets?eventId=${encodeURIComponent(event.id)}`;
          const status = statusLabels[event.status];
          const statusClass = statusClasses[event.status];

          return `
            <tr class="align-top hover:bg-zinc-50">
              <td class="min-w-72 px-4 py-3">
                <p class="font-medium text-zinc-950">${escapeHtml(event.name)}</p>
                <p class="mt-1 text-xs text-zinc-500">${escapeHtml(event.id)}</p>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(formatDate(event.date))}
              </td>
              <td class="px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(event.venue)}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(event.expectedAttendees)}
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <span class="rounded-md px-2 py-1 text-xs font-medium ${statusClass}">
                  ${status}
                </span>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                <div class="flex justify-end gap-2">
                  <a
                    class="inline-flex h-9 items-center rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
                    href="${ticketsUrl}"
                  >
                    Boletas
                  </a>
                  <a
                    class="inline-flex h-9 items-center rounded-md bg-zinc-950 px-3 text-sm font-medium text-white hover:bg-zinc-800"
                    href="${dashboardUrl}"
                  >
                    Tablero
                  </a>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
    };

    const loadEvents = async () => {
      const { eventsUrl } = getConfig();

      if (!eventsUrl) {
        setStatus("No se encontro la ruta de eventos.", "error");
        return;
      }

      setStatus("Cargando eventos.");

      try {
        const payload = await requestJson<unknown[]>(eventsUrl);
        const events = Array.isArray(payload) ? payload.filter(isEventRecord) : [];

        renderEvents(events);
        setStatus("Eventos actualizados.", "success");
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible cargar eventos.",
          "error"
        );
      }
    };

    const bindCreateForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-create-event-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { eventsUrl } = getConfig();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!eventsUrl) {
          setStatus("No se encontro la ruta de eventos.", "error");
          return;
        }

        const formData = new FormData(form);
        const date = toDateTimeLocal(String(formData.get("date") ?? ""));

        if (!date) {
          setStatus("La fecha del evento no es valida.", "error");
          return;
        }

        const payload = {
          date,
          expectedAttendees: Number(formData.get("expectedAttendees") ?? 0),
          name: String(formData.get("name") ?? "").trim(),
          status: String(formData.get("status") ?? "draft"),
          venue: String(formData.get("venue") ?? "").trim()
        };

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<EventRecord>(eventsUrl, {
            body: JSON.stringify(payload),
            method: "POST"
          });
          form.reset();
          setStatus("Evento creado.", "success");
          await loadEvents();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible crear el evento.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
        }
      });
    };

    const bindEventActions = () => {
      document.querySelector("[data-refresh-events]")?.addEventListener("click", () => {
        void loadEvents();
      });
    };

    try {
      const { authMeUrl } = getConfig();
      const token = sessionStorage.getItem("boletas.auth.token");
      const expiresAt = sessionStorage.getItem("boletas.auth.expiresAt");
      const user = readStoredUser();

      if (!authMeUrl || !token || isExpired(expiresAt) || !user) {
        redirectToLogin();
      } else {
        authToken = token;
        whenReady(() => {
          renderUser(user);
          bindLogout();
          bindCreateForm();
          bindEventActions();
        });

        validateSession(authMeUrl, token)
          .then((apiUser) => {
            sessionStorage.setItem("boletas.auth.user", JSON.stringify(apiUser));
            renderUser(apiUser);
            renderAdminOnly(apiUser);
            void loadEvents();
          })
          .catch(() => {
            redirectToLogin();
          });
      }
    } catch {
      redirectToLogin();
    }
  </script>

  <div class="grid min-h-screen lg:grid-cols-[240px_1fr]">
    <aside class="border-b border-zinc-200 bg-white px-4 py-4 lg:border-b-0 lg:border-r">
      <div class="flex h-full flex-col gap-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-950 text-white">
            <Ticket size={20} />
          </span>
          <div>
            <p class="text-sm font-semibold text-zinc-950">Boletas</p>
            <p class="text-xs text-zinc-500">Eventos</p>
          </div>
        </div>

        <nav class="grid gap-1 text-sm">
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/dashboard">
            Tablero
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-admin-only href="/users">
            Usuarios
          </a>
          <a class="rounded-md bg-zinc-950 px-3 py-2 font-medium text-white" href="/events">
            Eventos
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/tickets">
            Boletas
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/payments">
            Pagos
          </a>
        </nav>

        <div class="mt-auto rounded-lg border border-zinc-200 bg-zinc-50 p-3">
          <p class="text-xs font-medium text-zinc-500">Sesion</p>
          <p class="mt-1 truncate text-sm font-semibold text-zinc-950" data-auth-user-name>
            Usuario
          </p>
          <p class="mt-1 truncate text-xs text-zinc-500" data-auth-user-email>
            usuario@dominio.com
          </p>
        </div>
      </div>
    </aside>

    <main class="min-w-0">
      <header class="border-b border-zinc-200 bg-white px-4 py-4 sm:px-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <div class="flex items-center gap-2 text-xs font-medium text-zinc-500">
              <CalendarDays size={14} />
              <span>Agenda operativa</span>
            </div>
            <h1 class="mt-2 text-2xl font-semibold text-zinc-950">
              Eventos
            </h1>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-refresh-events
              title="Actualizar"
              type="button"
            >
              <RefreshCw size={17} />
              Actualizar
            </button>
            <div class="flex h-10 items-center gap-2 rounded-md border border-zinc-200 bg-white px-3">
              <ShieldCheck class="text-emerald-600" size={17} />
              <div class="hidden leading-tight sm:block">
                <p class="max-w-36 truncate text-xs font-semibold text-zinc-950" data-auth-user-name>
                  Usuario
                </p>
                <p class="text-[11px] uppercase text-zinc-500" data-auth-user-role>
                  Admin
                </p>
              </div>
            </div>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-logout-button
              title="Cerrar sesion"
              type="button"
            >
              <LogOut size={17} />
              Salir
            </button>
          </div>
        </div>
      </header>

      <div class="space-y-6 p-4 sm:p-6">
        <p class="hidden rounded-md border px-3 py-2 text-sm" data-events-status></p>

        <section class="grid gap-6 xl:grid-cols-[360px_1fr]">
          <section class="hidden rounded-lg border border-zinc-200 bg-white p-4 shadow-sm" data-admin-only>
            <div class="flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-zinc-950 text-white">
                <Plus size={18} />
              </span>
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Nuevo evento</h2>
                <p class="mt-1 text-xs text-zinc-500">Registro principal</p>
              </div>
            </div>

            <form class="mt-5 grid gap-4" data-create-event-form>
              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Nombre</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                  maxlength="120"
                  name="name"
                  required
                  type="text"
                />
              </label>

              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Fecha</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                  name="date"
                  required
                  type="datetime-local"
                />
              </label>

              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Lugar</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                  maxlength="160"
                  name="venue"
                  required
                  type="text"
                />
              </label>

              <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">Aforo esperado</span>
                  <input
                    class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                    min="0"
                    name="expectedAttendees"
                    required
                    type="number"
                    value="0"
                  />
                </label>

                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">Estado</span>
                  <select
                    class="h-10 rounded-md border border-zinc-200 bg-white px-3 text-sm outline-none focus:border-zinc-500"
                    name="status"
                  >
                    <option value="draft">Borrador</option>
                    <option value="active">Activo</option>
                    <option value="closed">Cerrado</option>
                  </select>
                </label>
              </div>

              <button
                class="inline-flex h-10 items-center justify-center rounded-md bg-zinc-950 px-4 text-sm font-semibold text-white hover:bg-zinc-800 disabled:cursor-not-allowed disabled:opacity-60"
                type="submit"
              >
                Crear evento
              </button>
            </form>
          </section>

          <section class="rounded-lg border border-zinc-200 bg-white shadow-sm">
            <div class="flex flex-col gap-3 border-b border-zinc-200 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Agenda</h2>
                <p class="mt-1 text-xs text-zinc-500">
                  <span data-events-count>0</span> registrados
                </p>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-zinc-100 text-left">
                <thead class="bg-zinc-50 text-xs uppercase text-zinc-500">
                  <tr>
                    <th class="px-4 py-3 font-medium">Evento</th>
                    <th class="px-4 py-3 font-medium">Fecha</th>
                    <th class="px-4 py-3 font-medium">Lugar</th>
                    <th class="px-4 py-3 font-medium">Aforo</th>
                    <th class="px-4 py-3 font-medium">Estado</th>
                    <th class="px-4 py-3 text-right font-medium">Accion</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 bg-white" data-events-body>
                  <tr>
                    <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="6">
                      Cargando eventos
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
