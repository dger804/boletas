---
import {
  CalendarDays,
  LogOut,
  Mail,
  NotebookText,
  Phone,
  Plus,
  RefreshCw,
  ShieldCheck,
  Ticket,
  UserRound,
  X
} from "lucide-astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? "/api";
const authMeUrl = `${apiBase}/auth/me`;
const eventsUrl = `${apiBase}/events`;
const ticketsUrl = `${apiBase}/tickets`;
const usersUrl = `${apiBase}/auth/users`;
---

<BaseLayout title="Boletas | Inventario">
  <span
    hidden
    data-auth-me-url={authMeUrl}
    data-events-url={eventsUrl}
    data-tickets-url={ticketsUrl}
    data-users-url={usersUrl}
  ></span>
  <script>
    type EventStatus = "draft" | "active" | "closed";
    type PaymentMethod = "cash" | "transfer";
    type TicketStatus =
      | "assigned"
      | "available"
      | "paid"
      | "reserved"
      | "sold"
      | "used"
      | "void";
    type UserRole = "regular" | "supervisor" | "admin";

    interface StoredUser {
      id: string;
      email: string;
      name: string;
      role: UserRole;
    }

    interface ManagedUser extends StoredUser {
      status: "active" | "disabled";
    }

    interface EventRecord {
      id: string;
      name: string;
      date: string;
      venue: string;
      status: EventStatus;
      expectedAttendees: number;
      createdAt: string;
    }

    interface DistributorRecord {
      id: string;
      eventId: string;
      userId?: string;
      name: string;
      phone: string;
      email?: string;
      notes?: string;
      createdAt: string;
    }

    interface TicketRecord {
      id: string;
      eventId: string;
      code: string;
      price: number;
      status: TicketStatus;
      distributorId?: string;
      distributorName?: string;
      distributorPhone?: string;
      distributorEmail?: string;
      distributorNotes?: string;
      recipientName?: string;
      buyerName?: string;
      buyerPhone?: string;
      paymentMethod?: PaymentMethod;
      soldAt?: string;
      paidAt?: string;
      usedAt?: string;
      checkedInBy?: string;
      capitalizationAmount: number;
      notes?: string;
      createdAt: string;
    }

    interface AuthMeResponse {
      user?: StoredUser;
    }

    const allowedRoles = new Set(["regular", "supervisor", "admin"]);
    const allowedEventStatuses = new Set(["draft", "active", "closed"]);
    const allowedTicketStatuses = new Set([
      "assigned",
      "available",
      "paid",
      "reserved",
      "sold",
      "used",
      "void"
    ]);
    const allowedPaymentMethods = new Set(["cash", "transfer"]);
    const roleLabels: Record<UserRole, string> = {
      admin: "Admin",
      regular: "Regular",
      supervisor: "Supervisor"
    };
    const ticketStatusLabels: Record<TicketStatus, string> = {
      assigned: "Asignada",
      available: "Disponible",
      paid: "Pagada",
      reserved: "Reservada",
      sold: "Vendida",
      used: "Usada",
      void: "Bloqueada"
    };
    const ticketStatusClasses: Record<TicketStatus, string> = {
      assigned: "bg-zinc-100 text-zinc-700",
      available: "bg-sky-50 text-sky-700",
      paid: "bg-emerald-50 text-emerald-700",
      reserved: "bg-violet-50 text-violet-700",
      sold: "bg-amber-50 text-amber-700",
      used: "bg-indigo-50 text-indigo-700",
      void: "bg-rose-50 text-rose-700"
    };
    const paymentMethodLabels: Record<PaymentMethod, string> = {
      cash: "Efectivo",
      transfer: "Transferencia"
    };

    let authToken = "";
    let currentUser: StoredUser | null = null;
    let currentEvents: EventRecord[] = [];
    let currentDistributors: DistributorRecord[] = [];
    let currentAssignableUsers: ManagedUser[] = [];
    let currentTickets: TicketRecord[] = [];
    let selectedTicketId = "";
    let selectedEventId = new URLSearchParams(window.location.search)
      .get("eventId")
      ?.trim() ?? "";
    const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);
    const money = new Intl.NumberFormat("es-CO", {
      currency: "COP",
      maximumFractionDigits: 0,
      style: "currency"
    });

    const resolveApiUrl = (url: string | null | undefined) => {
      if (!url) {
        return null;
      }

      if (url.startsWith("/api") && localHosts.has(window.location.hostname)) {
        return `http://localhost:3000${url}`;
      }

      return url;
    };

    const clearSession = () => {
      sessionStorage.removeItem("boletas.auth.token");
      sessionStorage.removeItem("boletas.auth.expiresAt");
      sessionStorage.removeItem("boletas.auth.user");
    };

    const redirectToLogin = () => {
      clearSession();
      window.location.replace("/login?reason=session-expired");
    };

    const getConfig = () => {
      const config = document.querySelector<HTMLElement>("[data-auth-me-url]");

      return {
        authMeUrl: resolveApiUrl(config?.dataset.authMeUrl),
        eventsUrl: resolveApiUrl(config?.dataset.eventsUrl),
        ticketsUrl: resolveApiUrl(config?.dataset.ticketsUrl),
        usersUrl: resolveApiUrl(config?.dataset.usersUrl)
      };
    };

    const isStoredUser = (value: unknown): value is StoredUser => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const user = value as Partial<StoredUser>;

      return (
        typeof user.id === "string" &&
        typeof user.email === "string" &&
        typeof user.name === "string" &&
        typeof user.role === "string" &&
        allowedRoles.has(user.role)
      );
    };

    const isManagedUser = (value: unknown): value is ManagedUser => {
      if (!isStoredUser(value) || typeof value !== "object") {
        return false;
      }

      const user = value as Partial<ManagedUser>;

      return user.status === "active" || user.status === "disabled";
    };

    const isEventRecord = (value: unknown): value is EventRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const event = value as Partial<EventRecord>;

      return (
        typeof event.id === "string" &&
        typeof event.name === "string" &&
        typeof event.date === "string" &&
        typeof event.venue === "string" &&
        typeof event.status === "string" &&
        allowedEventStatuses.has(event.status) &&
        typeof event.expectedAttendees === "number" &&
        typeof event.createdAt === "string"
      );
    };

    const isDistributorRecord = (value: unknown): value is DistributorRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const distributor = value as Partial<DistributorRecord>;
      const optionalStringIsValid = (field: unknown) =>
        typeof field === "undefined" || typeof field === "string";

      return (
        typeof distributor.id === "string" &&
        typeof distributor.eventId === "string" &&
        (distributor.userId === undefined || typeof distributor.userId === "string") &&
        typeof distributor.name === "string" &&
        typeof distributor.phone === "string" &&
        typeof distributor.createdAt === "string" &&
        optionalStringIsValid(distributor.email) &&
        optionalStringIsValid(distributor.notes)
      );
    };

    const isTicketRecord = (value: unknown): value is TicketRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const ticket = value as Partial<TicketRecord>;
      const optionalStringIsValid = (field: unknown) =>
        typeof field === "undefined" || typeof field === "string";
      const paymentMethodIsValid =
        typeof ticket.paymentMethod === "undefined" ||
        (typeof ticket.paymentMethod === "string" &&
          allowedPaymentMethods.has(ticket.paymentMethod));

      return (
        typeof ticket.id === "string" &&
        typeof ticket.eventId === "string" &&
        typeof ticket.code === "string" &&
        typeof ticket.price === "number" &&
        typeof ticket.status === "string" &&
        allowedTicketStatuses.has(ticket.status) &&
        typeof ticket.capitalizationAmount === "number" &&
        typeof ticket.createdAt === "string" &&
        optionalStringIsValid(ticket.distributorName) &&
        optionalStringIsValid(ticket.distributorPhone) &&
        optionalStringIsValid(ticket.distributorEmail) &&
        optionalStringIsValid(ticket.distributorNotes) &&
        paymentMethodIsValid
      );
    };

    const readStoredUser = (): StoredUser | null => {
      const storedUser = sessionStorage.getItem("boletas.auth.user");

      if (!storedUser) {
        return null;
      }

      try {
        const parsed = JSON.parse(storedUser) as unknown;

        return isStoredUser(parsed) ? parsed : null;
      } catch {
        return null;
      }
    };

    const isExpired = (expiresAt: string | null) => {
      const expiresAtMs = expiresAt ? Date.parse(expiresAt) : Number.NaN;

      return !Number.isFinite(expiresAtMs) || expiresAtMs <= Date.now();
    };

    const whenReady = (callback: () => void) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", callback, { once: true });
      } else {
        callback();
      }
    };

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");

    const renderUser = (user: StoredUser) => {
      currentUser = user;

      document.querySelectorAll("[data-auth-user-name]").forEach((element) => {
        element.textContent = user.name;
      });

      document.querySelectorAll("[data-auth-user-email]").forEach((element) => {
        element.textContent = user.email;
      });

      document.querySelectorAll("[data-auth-user-role]").forEach((element) => {
        element.textContent = roleLabels[user.role];
      });
    };

    const renderAdminOnly = (user: StoredUser) => {
      document.querySelectorAll<HTMLElement>("[data-admin-only]").forEach((element) => {
        element.classList.toggle("hidden", user.role !== "admin");
      });

      document.querySelectorAll<HTMLElement>("[data-manager-only]").forEach((element) => {
        element.classList.toggle("hidden", !["admin", "supervisor"].includes(user.role));
      });
    };

    const renderAssignableUsers = () => {
      const selector = document.querySelector<HTMLSelectElement>("[data-distributor-user]");

      if (!selector) {
        return;
      }

      selector.innerHTML = [
        `<option value="">Sin cuenta vinculada</option>`,
        ...currentAssignableUsers.map(
          (user) =>
            `<option value="${escapeHtml(user.id)}">${escapeHtml(user.name)} - ${escapeHtml(roleLabels[user.role])}</option>`
        )
      ].join("");
    };

    const bindLogout = () => {
      document.querySelectorAll("[data-logout-button]").forEach((button) => {
        button.addEventListener("click", () => {
          clearSession();
          window.location.replace("/login");
        });
      });
    };

    const setStatus = (message: string, tone: "neutral" | "success" | "error" = "neutral") => {
      const element = document.querySelector<HTMLElement>("[data-tickets-status]");

      if (!element) {
        return;
      }

      const toneClasses = {
        error: "border-rose-200 bg-rose-50 text-rose-700",
        neutral: "border-zinc-200 bg-white text-zinc-600",
        success: "border-emerald-200 bg-emerald-50 text-emerald-700"
      };

      element.className = `rounded-md border px-3 py-2 text-sm ${toneClasses[tone]}`;
      element.textContent = message;
      element.classList.remove("hidden");
    };

    const validateSession = async (url: string, token: string) => {
      const response = await fetch(url, {
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error(`Auth session rejected with ${response.status}`);
      }

      const payload = (await response.json()) as AuthMeResponse;

      if (!isStoredUser(payload.user)) {
        throw new Error("Auth session response did not include a valid user.");
      }

      return payload.user;
    };

    const requestJson = async <T,>(url: string, options: RequestInit = {}) => {
      const response = await fetch(url, {
        ...options,
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${authToken}`,
          ...(options.body ? { "Content-Type": "application/json" } : {}),
          ...options.headers
        }
      });

      if (response.status === 401 || response.status === 403) {
        redirectToLogin();
      }

      if (!response.ok) {
        let message = `Solicitud rechazada con estado ${response.status}.`;

        try {
          const payload = (await response.json()) as { message?: string };

          if (payload.message) {
            message = payload.message;
          }
        } catch {
          // Keep the generic message.
        }

        throw new Error(message);
      }

      return (await response.json()) as T;
    };

    const formatDate = (value?: string) => {
      if (!value) {
        return "Sin registro";
      }

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return "Sin registro";
      }

      return new Intl.DateTimeFormat("es-CO", {
        dateStyle: "medium",
        timeStyle: "short"
      }).format(date);
    };

    const getSelectedEvent = () =>
      currentEvents.find((event) => event.id === selectedEventId) ?? currentEvents[0] ?? null;

    const isSelectedEventClosed = () => getSelectedEvent()?.status === "closed";

    const canManageTickets = () =>
      currentUser?.role === "admin" || currentUser?.role === "supervisor";

    const isReservableTicket = (ticket: TicketRecord) =>
      !isSelectedEventClosed() &&
      ["assigned", "available", "reserved"].includes(ticket.status);

    const isReservationReleaseableTicket = (ticket: TicketRecord) =>
      !isSelectedEventClosed() && ticket.status === "reserved";

    const isSaleableTicket = (ticket: TicketRecord) =>
      !isSelectedEventClosed() &&
      ["assigned", "available", "reserved"].includes(ticket.status);

    const isAssignableTicket = (ticket: TicketRecord) =>
      !isSelectedEventClosed() &&
      ["assigned", "available", "reserved"].includes(ticket.status);

    const isVoidableTicket = (ticket: TicketRecord) => {
      if (
        isSelectedEventClosed() ||
        !canManageTickets() ||
        ["used", "void"].includes(ticket.status)
      ) {
        return false;
      }

      return ticket.status !== "paid" || currentUser?.role === "admin";
    };

    const getSelectedTicket = () =>
      currentTickets.find((ticket) => ticket.id === selectedTicketId) ?? null;

    const updateSelectedEvent = (eventId: string) => {
      selectedEventId = eventId;
      const selector = document.querySelector<HTMLSelectElement>("[data-event-selector]");

      if (selector) {
        selector.value = selectedEventId;
      }

      const query = new URLSearchParams(window.location.search);
      query.set("eventId", selectedEventId);
      window.history.replaceState(null, "", `${window.location.pathname}?${query.toString()}`);
    };

    const renderEventOptions = () => {
      const selector = document.querySelector<HTMLSelectElement>("[data-event-selector]");
      const batchEventName = document.querySelector<HTMLElement>("[data-batch-event-name]");
      const responsibleEventNames = document.querySelectorAll<HTMLElement>(
        "[data-responsible-event-name]"
      );

      if (!selector) {
        return;
      }

      if (currentEvents.length === 0) {
        selector.innerHTML = `<option value="">Sin eventos</option>`;
        selector.setAttribute("disabled", "true");
        if (batchEventName) {
          batchEventName.textContent = "Selecciona un evento";
        }
        responsibleEventNames.forEach((element) => {
          element.textContent = "Selecciona un evento";
        });
        return;
      }

      if (!currentEvents.some((event) => event.id === selectedEventId)) {
        selectedEventId = currentEvents[0].id;
      }

      selector.removeAttribute("disabled");
      selector.innerHTML = currentEvents
        .map(
          (event) =>
            `<option value="${escapeHtml(event.id)}"${event.id === selectedEventId ? " selected" : ""}>${escapeHtml(event.name)}</option>`
        )
        .join("");

      if (batchEventName) {
        batchEventName.textContent = getSelectedEvent()?.name ?? "Selecciona un evento";
      }

      responsibleEventNames.forEach((element) => {
        element.textContent = getSelectedEvent()?.name ?? "Selecciona un evento";
      });
    };

    const updateSalePanel = () => {
      const ticket = getSelectedTicket();
      const selectedCode = document.querySelector<HTMLElement>("[data-sale-ticket-code]");
      const submitButton = document.querySelector<HTMLButtonElement>("[data-register-sale-submit]");
      const form = document.querySelector<HTMLFormElement>("[data-register-sale-form]");

      if (selectedCode) {
        selectedCode.textContent = ticket
          ? `Boleta ${ticket.code}`
          : "Selecciona una boleta";
      }

      if (submitButton) {
        submitButton.disabled = !ticket || !isSaleableTicket(ticket);
      }

      if (!form || !ticket) {
        return;
      }

      const amount = form.querySelector<HTMLInputElement>('[name="amount"]');
      const buyerName = form.querySelector<HTMLInputElement>('[name="buyerName"]');
      const capitalizationAmount = form.querySelector<HTMLInputElement>(
        '[name="capitalizationAmount"]'
      );

      if (amount) {
        amount.value = String(ticket.price);
      }

      if (buyerName) {
        buyerName.value = ticket.recipientName ?? "";
      }

      if (capitalizationAmount) {
        capitalizationAmount.value = String(ticket.capitalizationAmount);
      }
    };

    const renderDistributors = () => {
      const count = document.querySelector<HTMLElement>("[data-distributors-count]");
      const list = document.querySelector<HTMLElement>("[data-distributors-list]");
      const selector = document.querySelector<HTMLSelectElement>(
        "[data-assignment-distributor]"
      );

      if (count) {
        count.textContent = `${currentDistributors.length}`;
      }

      if (selector) {
        if (currentDistributors.length === 0) {
          selector.innerHTML = `<option value="">Sin responsables</option>`;
          selector.disabled = true;
        } else {
          selector.disabled = false;
          selector.innerHTML = currentDistributors
            .map(
              (distributor) =>
                `<option value="${escapeHtml(distributor.id)}">${escapeHtml(distributor.name)}</option>`
            )
            .join("");
        }
      }

      if (!list) {
        return;
      }

      if (currentDistributors.length === 0) {
        list.innerHTML = `
          <li class="rounded-md border border-dashed border-zinc-200 px-3 py-3 text-sm text-zinc-500">
            Sin responsables creados para este evento
          </li>
        `;
        return;
      }

      list.innerHTML = currentDistributors
        .map(
          (distributor) => `
            <li class="rounded-md border border-zinc-100 px-3 py-3">
              <p class="truncate text-sm font-semibold text-zinc-950">
                ${escapeHtml(distributor.name)}
              </p>
              <p class="mt-1 truncate text-xs text-zinc-500">
                ${escapeHtml(distributor.phone)}
              </p>
              ${
                distributor.userId
                  ? `<p class="mt-1 truncate text-[11px] uppercase text-zinc-500">Cuenta vinculada</p>`
                  : ""
              }
            </li>
          `
        )
        .join("");
    };

    const updateAssignmentPanel = () => {
      const ticket = getSelectedTicket();
      const selectedCode = document.querySelector<HTMLElement>("[data-assignment-ticket-code]");
      const submitButton = document.querySelector<HTMLButtonElement>(
        "[data-assign-ticket-submit]"
      );

      if (selectedCode) {
        selectedCode.textContent = ticket
          ? `Boleta ${ticket.code}`
          : "Selecciona una boleta";
      }

      if (submitButton) {
        submitButton.disabled =
          !canManageTickets() ||
          !ticket ||
          !isAssignableTicket(ticket) ||
          currentDistributors.length === 0;
      }
    };

    const updateReservationPanel = () => {
      const ticket = getSelectedTicket();
      const selectedCode = document.querySelector<HTMLElement>("[data-reserve-ticket-code]");
      const submitButton = document.querySelector<HTMLButtonElement>("[data-reserve-ticket-submit]");
      const form = document.querySelector<HTMLFormElement>("[data-reserve-ticket-form]");

      if (selectedCode) {
        selectedCode.textContent = ticket
          ? `Boleta ${ticket.code}`
          : "Selecciona una boleta";
      }

      if (submitButton) {
        submitButton.disabled = !ticket || !isReservableTicket(ticket);
      }

      if (!form) {
        return;
      }

      if (!ticket) {
        form.reset();
        return;
      }

      const recipientName = form.querySelector<HTMLInputElement>('[name="recipientName"]');
      const notes = form.querySelector<HTMLTextAreaElement>('[name="notes"]');

      if (recipientName) {
        recipientName.value = ticket.recipientName ?? "";
      }

      if (notes) {
        notes.value = ticket.notes ?? "";
      }
    };

    const updateSelectedTicketPanels = () => {
      updateSalePanel();
      updateReservationPanel();
      updateAssignmentPanel();
    };

    const selectTicketForSale = (ticketId: string) => {
      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      if (!isSaleableTicket(ticket)) {
        setStatus("Esta boleta ya no permite registrar venta.", "error");
        return;
      }

      selectedTicketId = ticket.id;
      updateSelectedTicketPanels();
      setStatus(`Venta preparada para ${ticket.code}.`);
    };

    const selectTicketForReservation = (ticketId: string) => {
      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      if (!isReservableTicket(ticket)) {
        setStatus("Esta boleta ya no permite reserva.", "error");
        return;
      }

      selectedTicketId = ticket.id;
      updateSelectedTicketPanels();
      setStatus(`Reserva preparada para ${ticket.code}.`);
    };

    const selectTicketForAssignment = (ticketId: string) => {
      if (!canManageTickets()) {
        setStatus("Tu rol no permite asignar responsables.", "error");
        return;
      }

      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      if (!isAssignableTicket(ticket)) {
        setStatus("Esta boleta ya no permite cambiar responsable.", "error");
        return;
      }

      selectedTicketId = ticket.id;
      updateSelectedTicketPanels();
      setStatus(`Asignacion preparada para ${ticket.code}.`);
    };

    const voidSelectedTicket = async (ticketId: string) => {
      const { ticketsUrl } = getConfig();
      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticketsUrl || !ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      if (!isVoidableTicket(ticket)) {
        setStatus("Esta boleta no puede anularse con tu rol o estado actual.", "error");
        return;
      }

      const reason = window.prompt(
        `Motivo para anular la boleta ${ticket.code}`,
        ""
      );

      if (reason === null) {
        return;
      }

      const confirmed = window.confirm(
        `Confirmar anulacion de la boleta ${ticket.code}. Esta accion bloquea venta, pago e ingreso.`
      );

      if (!confirmed) {
        return;
      }

      setStatus(`Anulando boleta ${ticket.code}.`);

      try {
        await requestJson<TicketRecord>(
          `${ticketsUrl}/${encodeURIComponent(ticket.id)}/void`,
          {
            body: JSON.stringify({
              ...(reason.trim() ? { reason: reason.trim() } : {})
            }),
            method: "PATCH"
          }
        );
        selectedTicketId = "";
        setStatus(`Boleta ${ticket.code} anulada.`, "success");
        await loadTickets();
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible anular la boleta.",
          "error"
        );
      } finally {
        updateSelectedTicketPanels();
      }
    };

    const releaseTicketReservation = async (ticketId: string) => {
      const { ticketsUrl } = getConfig();
      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticketsUrl || !ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      if (!isReservationReleaseableTicket(ticket)) {
        setStatus("Solo se pueden liberar boletas reservadas.", "error");
        return;
      }

      const confirmed = window.confirm(
        `Confirmar liberacion de la reserva de la boleta ${ticket.code}.`
      );

      if (!confirmed) {
        return;
      }

      setStatus(`Liberando reserva de ${ticket.code}.`);

      try {
        await requestJson<TicketRecord>(
          `${ticketsUrl}/${encodeURIComponent(ticket.id)}/release`,
          {
            body: JSON.stringify({}),
            method: "PATCH"
          }
        );
        selectedTicketId = "";
        setStatus(`Reserva de ${ticket.code} liberada.`, "success");
        await loadTickets();
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible liberar la reserva.",
          "error"
        );
      } finally {
        updateSelectedTicketPanels();
      }
    };

    const hideResponsibleDetails = () => {
      const dialog = document.querySelector<HTMLElement>("[data-responsible-dialog]");
      dialog?.classList.add("hidden");
      dialog?.setAttribute("aria-hidden", "true");
    };

    const setResponsibleText = (selector: string, value: string) => {
      const element = document.querySelector<HTMLElement>(selector);

      if (element) {
        element.textContent = value;
      }
    };

    const setResponsibleLink = (selector: string, value: string, href: string) => {
      const link = document.querySelector<HTMLAnchorElement>(selector);

      if (!link) {
        return;
      }

      link.textContent = value;
      link.href = href;
      link.classList.add("inline-flex");
      link.classList.remove("hidden");
    };

    const clearResponsibleLink = (selector: string) => {
      const link = document.querySelector<HTMLAnchorElement>(selector);

      if (!link) {
        return;
      }

      link.textContent = "";
      link.removeAttribute("href");
      link.classList.remove("inline-flex");
      link.classList.add("hidden");
    };

    const showResponsibleDetails = (ticketId: string) => {
      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      const dialog = document.querySelector<HTMLElement>("[data-responsible-dialog]");
      const closeButton = document.querySelector<HTMLButtonElement>(
        "[data-close-responsible-details]"
      );
      const name =
        ticket.distributorName?.trim() ||
        (ticket.distributorId ? "Responsable asignado" : "Sin responsable");
      const phone = ticket.distributorPhone?.trim() ?? "";
      const email = ticket.distributorEmail?.trim() ?? "";
      const notes = ticket.distributorNotes?.trim() ?? "";

      setResponsibleText("[data-responsible-name]", name);
      setResponsibleText("[data-responsible-ticket]", `Boleta ${ticket.code}`);
      setResponsibleText(
        "[data-responsible-phone]",
        phone || "Sin telefono registrado"
      );
      setResponsibleText(
        "[data-responsible-email]",
        email || "Sin correo registrado"
      );
      setResponsibleText(
        "[data-responsible-notes]",
        notes || "Sin notas registradas"
      );

      if (phone) {
        setResponsibleLink(
          "[data-responsible-call]",
          "Llamar",
          `tel:${phone.replace(/[^\d+]/g, "")}`
        );
      } else {
        clearResponsibleLink("[data-responsible-call]");
      }

      if (email) {
        setResponsibleLink("[data-responsible-mail]", "Escribir", `mailto:${email}`);
      } else {
        clearResponsibleLink("[data-responsible-mail]");
      }

      dialog?.classList.remove("hidden");
      dialog?.setAttribute("aria-hidden", "false");
      closeButton?.focus();
    };

    const renderTickets = (tickets: TicketRecord[]) => {
      const body = document.querySelector<HTMLElement>("[data-tickets-body]");
      const count = document.querySelector<HTMLElement>("[data-tickets-count]");
      const total = document.querySelector<HTMLElement>("[data-tickets-total]");
      const reserved = document.querySelector<HTMLElement>("[data-tickets-reserved]");
      const capitalization = document.querySelector<HTMLElement>("[data-tickets-capitalization]");

      if (count) {
        count.textContent = `${tickets.length}`;
      }

      if (total) {
        total.textContent = money.format(
          tickets.reduce((sum, ticket) => sum + ticket.price, 0)
        );
      }

      if (reserved) {
        reserved.textContent = `${tickets.filter((ticket) => ticket.status === "reserved").length}`;
      }

      if (capitalization) {
        capitalization.textContent = money.format(
          tickets.reduce((sum, ticket) => sum + ticket.capitalizationAmount, 0)
        );
      }

      if (!body) {
        return;
      }

      if (tickets.length === 0) {
        body.innerHTML = `
          <tr>
            <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="9">
              Sin boletas registradas para este evento
            </td>
          </tr>
        `;
        return;
      }

      body.innerHTML = tickets
        .map((ticket) => {
          const statusLabel = ticketStatusLabels[ticket.status];
          const statusClass = ticketStatusClasses[ticket.status];
          const holder =
            ticket.buyerName ??
            ticket.recipientName ??
            "Sin titular";
          const responsible =
            ticket.distributorName?.trim() ||
            (ticket.distributorId ? "Responsable asignado" : "Sin responsable");
          const responsibleCell = ticket.distributorId
            ? `
              <button
                class="group inline-flex max-w-56 flex-col items-start text-left"
                data-show-responsible="${escapeHtml(ticket.id)}"
                title="Ver contacto del responsable"
                type="button"
              >
                <span class="max-w-56 truncate font-medium text-zinc-900 underline-offset-4 group-hover:underline">
                  ${escapeHtml(responsible)}
                </span>
                <span class="text-xs text-zinc-400 group-hover:text-zinc-600">
                  Ver contacto
                </span>
              </button>
            `
            : `<span class="text-zinc-500">${escapeHtml(responsible)}</span>`;
          const paymentMethod = ticket.paymentMethod
            ? paymentMethodLabels[ticket.paymentMethod]
            : "Sin pago";
          const assignButton =
            canManageTickets() && isAssignableTicket(ticket)
              ? `
                <button
                  class="inline-flex h-9 items-center rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
                  data-select-ticket-assignment="${escapeHtml(ticket.id)}"
                  type="button"
                >
                  Asignar
                </button>
              `
              : "";
          const reserveButton = isReservableTicket(ticket)
            ? `
              <button
                class="inline-flex h-9 items-center rounded-md border border-violet-200 px-3 text-sm font-medium text-violet-700 hover:bg-violet-50"
                data-select-ticket-reservation="${escapeHtml(ticket.id)}"
                type="button"
              >
                ${ticket.status === "reserved" ? "Editar reserva" : "Reservar"}
              </button>
            `
            : "";
          const releaseButton = isReservationReleaseableTicket(ticket)
            ? `
              <button
                class="inline-flex h-9 items-center rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
                data-release-ticket-reservation="${escapeHtml(ticket.id)}"
                type="button"
              >
                Liberar
              </button>
            `
            : "";
          const saleButton = isSaleableTicket(ticket)
            ? `
              <button
                class="inline-flex h-9 items-center rounded-md bg-zinc-950 px-3 text-sm font-medium text-white hover:bg-zinc-800"
                data-select-ticket-sale="${escapeHtml(ticket.id)}"
                type="button"
              >
                Venta
              </button>
            `
            : `<span class="text-xs text-zinc-400">No disponible</span>`;
          const voidButton = isVoidableTicket(ticket)
            ? `
              <button
                class="inline-flex h-9 items-center rounded-md border border-rose-200 px-3 text-sm font-medium text-rose-700 hover:bg-rose-50"
                data-void-ticket="${escapeHtml(ticket.id)}"
                type="button"
              >
                Anular
              </button>
            `
            : "";
          const actionButtons = `
            <div class="flex flex-wrap justify-end gap-2">
              ${assignButton}
              ${reserveButton}
              ${releaseButton}
              ${saleButton}
              ${voidButton}
            </div>
          `;

          return `
            <tr class="align-top hover:bg-zinc-50">
              <td class="whitespace-nowrap px-4 py-3 font-medium text-zinc-950">
                ${escapeHtml(ticket.code)}
              </td>
              <td class="min-w-56 px-4 py-3 text-sm text-zinc-600">
                ${responsibleCell}
              </td>
              <td class="min-w-56 px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(holder)}
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <span class="rounded-md px-2 py-1 text-xs font-medium ${statusClass}">
                  ${escapeHtml(statusLabel)}
                </span>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(paymentMethod)}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right text-sm font-semibold text-zinc-950">
                ${escapeHtml(money.format(ticket.price))}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right text-sm text-zinc-600">
                ${escapeHtml(money.format(ticket.capitalizationAmount))}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(formatDate(ticket.createdAt))}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                ${actionButtons}
              </td>
            </tr>
          `;
        })
        .join("");
    };

    const loadDistributors = async () => {
      const { eventsUrl } = getConfig();

      if (!canManageTickets() || !eventsUrl || !selectedEventId) {
        currentDistributors = [];
        renderDistributors();
        updateAssignmentPanel();
        return;
      }

      const url = `${eventsUrl}/${encodeURIComponent(selectedEventId)}/distributors`;
      const payload = await requestJson<unknown[]>(url);
      currentDistributors = Array.isArray(payload)
        ? payload.filter(isDistributorRecord)
        : [];
      renderDistributors();
      updateAssignmentPanel();
    };

    const loadAssignableUsers = async () => {
      const { usersUrl } = getConfig();

      if (currentUser?.role !== "admin" || !usersUrl) {
        currentAssignableUsers = [];
        renderAssignableUsers();
        return;
      }

      const payload = await requestJson<{ users?: unknown[] }>(usersUrl);
      currentAssignableUsers = Array.isArray(payload.users)
        ? payload.users.filter(isManagedUser).filter((user) => user.status === "active")
        : [];
      renderAssignableUsers();
    };

    const loadTickets = async () => {
      const { ticketsUrl } = getConfig();

      if (!ticketsUrl) {
        setStatus("No se encontro la ruta de boletas.", "error");
        return;
      }

      if (!selectedEventId) {
        currentTickets = [];
        currentDistributors = [];
        selectedTicketId = "";
        renderTickets([]);
        renderDistributors();
        updateSelectedTicketPanels();
        setStatus("Selecciona un evento para ver sus boletas.");
        return;
      }

      setStatus("Cargando boletas.");

      try {
        let distributorsLoadFailed = false;

        try {
          await loadDistributors();
        } catch (error) {
          distributorsLoadFailed = true;
          setStatus(
            error instanceof Error ? error.message : "No fue posible cargar responsables.",
            "error"
          );
        }

        const url = `${ticketsUrl}?eventId=${encodeURIComponent(selectedEventId)}`;
        const payload = await requestJson<unknown[]>(url);
        const tickets = Array.isArray(payload) ? payload.filter(isTicketRecord) : [];

        currentTickets = tickets;
        if (
          !currentTickets.some(
            (ticket) =>
              ticket.id === selectedTicketId &&
              (isSaleableTicket(ticket) ||
                isAssignableTicket(ticket) ||
                isReservableTicket(ticket))
          )
        ) {
          selectedTicketId = "";
        }
        renderTickets(tickets);
        updateSelectedTicketPanels();
        setStatus(
          distributorsLoadFailed
            ? "Boletas actualizadas, pero no fue posible cargar responsables."
            : "Boletas actualizadas.",
          distributorsLoadFailed ? "error" : "success"
        );
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible cargar boletas.",
          "error"
        );
      }
    };

    const loadEvents = async () => {
      const { eventsUrl } = getConfig();

      if (!eventsUrl) {
        setStatus("No se encontro la ruta de eventos.", "error");
        return;
      }

      setStatus("Cargando eventos.");

      try {
        const payload = await requestJson<unknown[]>(eventsUrl);
        currentEvents = Array.isArray(payload) ? payload.filter(isEventRecord) : [];
        renderEventOptions();

        if (selectedEventId) {
          await loadTickets();
        } else {
          currentTickets = [];
          currentDistributors = [];
          selectedTicketId = "";
          renderTickets([]);
          renderDistributors();
          updateSelectedTicketPanels();
          setStatus("No hay eventos para consultar.");
        }
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible cargar eventos.",
          "error"
        );
      }
    };

    const bindTicketActions = () => {
      document.querySelector("[data-refresh-tickets]")?.addEventListener("click", () => {
        void loadEvents();
      });

      document
        .querySelector<HTMLSelectElement>("[data-event-selector]")
        ?.addEventListener("change", (event) => {
          const target = event.currentTarget as HTMLSelectElement;
          updateSelectedEvent(target.value);
          void loadTickets();
        });

      document.querySelector("[data-tickets-body]")?.addEventListener("click", (event) => {
        const target = event.target;

        if (!(target instanceof HTMLElement)) {
          return;
        }

        const responsibleButton = target.closest<HTMLButtonElement>(
          "[data-show-responsible]"
        );

        if (responsibleButton?.dataset.showResponsible) {
          showResponsibleDetails(responsibleButton.dataset.showResponsible);
          return;
        }

        const assignmentButton = target.closest<HTMLButtonElement>(
          "[data-select-ticket-assignment]"
        );

        if (assignmentButton?.dataset.selectTicketAssignment) {
          selectTicketForAssignment(assignmentButton.dataset.selectTicketAssignment);
          return;
        }

        const reservationButton = target.closest<HTMLButtonElement>(
          "[data-select-ticket-reservation]"
        );

        if (reservationButton?.dataset.selectTicketReservation) {
          selectTicketForReservation(reservationButton.dataset.selectTicketReservation);
          return;
        }

        const releaseReservationButton = target.closest<HTMLButtonElement>(
          "[data-release-ticket-reservation]"
        );

        if (releaseReservationButton?.dataset.releaseTicketReservation) {
          void releaseTicketReservation(
            releaseReservationButton.dataset.releaseTicketReservation
          );
          return;
        }

        const voidButton = target.closest<HTMLButtonElement>("[data-void-ticket]");

        if (voidButton?.dataset.voidTicket) {
          void voidSelectedTicket(voidButton.dataset.voidTicket);
          return;
        }

        const saleButton = target.closest<HTMLButtonElement>("[data-select-ticket-sale]");

        if (!saleButton?.dataset.selectTicketSale) {
          return;
        }

        selectTicketForSale(saleButton.dataset.selectTicketSale);
      });

      document.querySelectorAll("[data-close-responsible-details]").forEach((button) => {
        button.addEventListener("click", hideResponsibleDetails);
      });

      document
        .querySelector("[data-responsible-dialog]")
        ?.addEventListener("click", (event) => {
          if (event.target === event.currentTarget) {
            hideResponsibleDetails();
          }
        });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          hideResponsibleDetails();
        }
      });
    };

    const bindCreateDistributorForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-create-distributor-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { eventsUrl } = getConfig();
        const selectedEvent = getSelectedEvent();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!canManageTickets() || !eventsUrl || !selectedEvent) {
          setStatus("Tu rol no permite crear responsables para este evento.", "error");
          return;
        }

        if (selectedEvent.status === "closed") {
          setStatus("El evento esta cerrado y no acepta cambios operativos.", "error");
          return;
        }

        const formData = new FormData(form);
        const email = String(formData.get("email") ?? "").trim();
        const notes = String(formData.get("notes") ?? "").trim();
        const userId = String(formData.get("userId") ?? "").trim();
        const payload = {
          name: String(formData.get("name") ?? "").trim(),
          phone: String(formData.get("phone") ?? "").trim(),
          ...(email ? { email } : {}),
          ...(notes ? { notes } : {}),
          ...(currentUser?.role === "admin" && userId ? { userId } : {})
        };

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<DistributorRecord>(
            `${eventsUrl}/${encodeURIComponent(selectedEvent.id)}/distributors`,
            {
              body: JSON.stringify(payload),
              method: "POST"
            }
          );
          form.reset();
          setStatus("Responsable creado.", "success");
          await loadDistributors();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible crear el responsable.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
        }
      });
    };

    const bindReserveTicketForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-reserve-ticket-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { ticketsUrl } = getConfig();
        const ticket = getSelectedTicket();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!ticketsUrl || !ticket) {
          setStatus("Selecciona una boleta antes de reservar.", "error");
          return;
        }

        if (!isReservableTicket(ticket)) {
          setStatus("Esta boleta ya no permite reserva.", "error");
          return;
        }

        const formData = new FormData(form);
        const notes = String(formData.get("notes") ?? "").trim();
        const recipientName = String(formData.get("recipientName") ?? "").trim();

        if (!recipientName) {
          setStatus("Registra el titular de la reserva.", "error");
          return;
        }

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<TicketRecord>(
            `${ticketsUrl}/${encodeURIComponent(ticket.id)}/reserve`,
            {
              body: JSON.stringify({
                recipientName,
                ...(notes ? { notes } : {})
              }),
              method: "PATCH"
            }
          );
          form.reset();
          selectedTicketId = "";
          setStatus(`Boleta ${ticket.code} reservada.`, "success");
          await loadTickets();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible reservar la boleta.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
          updateSelectedTicketPanels();
        }
      });
    };

    const bindAssignTicketForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-assign-ticket-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { ticketsUrl } = getConfig();
        const ticket = getSelectedTicket();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!canManageTickets() || !ticketsUrl || !ticket) {
          setStatus("Selecciona una boleta antes de asignar responsable.", "error");
          return;
        }

        if (!isAssignableTicket(ticket)) {
          setStatus("Esta boleta ya no permite cambiar responsable.", "error");
          return;
        }

        const formData = new FormData(form);
        const distributorId = String(formData.get("distributorId") ?? "").trim();
        const notes = String(formData.get("notes") ?? "").trim();
        const recipientName = String(formData.get("recipientName") ?? "").trim();

        if (!distributorId) {
          setStatus("Selecciona un responsable.", "error");
          return;
        }

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<TicketRecord>(
            `${ticketsUrl}/${encodeURIComponent(ticket.id)}/assign`,
            {
              body: JSON.stringify({
                distributorId,
                ...(notes ? { notes } : {}),
                ...(recipientName ? { recipientName } : {})
              }),
              method: "PATCH"
            }
          );
          form.reset();
          selectedTicketId = "";
          setStatus("Responsable asignado a la boleta.", "success");
          await loadTickets();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible asignar responsable.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
          updateSelectedTicketPanels();
        }
      });
    };

    const bindCreateBatchForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-create-ticket-batch-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { eventsUrl } = getConfig();
        const selectedEvent = getSelectedEvent();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!eventsUrl || !selectedEvent) {
          setStatus("Selecciona un evento antes de crear boletas.", "error");
          return;
        }

        if (selectedEvent.status === "closed") {
          setStatus("El evento esta cerrado y no acepta cambios operativos.", "error");
          return;
        }

        const formData = new FormData(form);
        const payload = {
          capitalizationAmount: Number(formData.get("capitalizationAmount") ?? 0),
          codePrefix: String(formData.get("codePrefix") ?? "").trim() || undefined,
          price: Number(formData.get("price") ?? 0),
          quantity: Number(formData.get("quantity") ?? 0)
        };

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<TicketRecord[]>(
            `${eventsUrl}/${encodeURIComponent(selectedEvent.id)}/tickets/batch`,
            {
              body: JSON.stringify(payload),
              method: "POST"
            }
          );
          form.reset();
          setStatus("Lote de boletas creado.", "success");
          await loadTickets();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible crear el lote.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
        }
      });
    };

    const bindRegisterSaleForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-register-sale-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { ticketsUrl } = getConfig();
        const ticket = getSelectedTicket();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!ticketsUrl || !ticket) {
          setStatus("Selecciona una boleta antes de registrar la venta.", "error");
          return;
        }

        if (!isSaleableTicket(ticket)) {
          setStatus("Esta boleta ya no permite registrar venta.", "error");
          return;
        }

        const formData = new FormData(form);
        const buyerPhone = String(formData.get("buyerPhone") ?? "").trim();
        const evidenceUrl = String(formData.get("evidenceUrl") ?? "").trim();
        const notes = String(formData.get("notes") ?? "").trim();
        const reference = String(formData.get("reference") ?? "").trim();
        const payload = {
          amount: Number(formData.get("amount") ?? ticket.price),
          buyerName: String(formData.get("buyerName") ?? "").trim(),
          capitalizationAmount: Number(
            formData.get("capitalizationAmount") ?? ticket.capitalizationAmount
          ),
          method: String(formData.get("method") ?? "cash"),
          ...(buyerPhone ? { buyerPhone } : {}),
          ...(evidenceUrl ? { evidenceUrl } : {}),
          ...(notes ? { notes } : {}),
          ...(reference ? { reference } : {})
        };

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<{ payment: unknown; ticket: TicketRecord }>(
            `${ticketsUrl}/${encodeURIComponent(ticket.id)}/sale`,
            {
              body: JSON.stringify(payload),
              method: "PATCH"
            }
          );
          form.reset();
          selectedTicketId = "";
          setStatus("Venta registrada. El pago queda pendiente de validacion.", "success");
          await loadTickets();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible registrar la venta.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
          updateSelectedTicketPanels();
        }
      });
    };

    try {
      const { authMeUrl } = getConfig();
      const token = sessionStorage.getItem("boletas.auth.token");
      const expiresAt = sessionStorage.getItem("boletas.auth.expiresAt");
      const user = readStoredUser();

      if (!authMeUrl || !token || isExpired(expiresAt) || !user) {
        redirectToLogin();
      } else {
        authToken = token;
        whenReady(() => {
          renderUser(user);
          bindLogout();
          bindTicketActions();
          bindCreateDistributorForm();
          bindReserveTicketForm();
          bindAssignTicketForm();
          bindCreateBatchForm();
          bindRegisterSaleForm();
        });

        validateSession(authMeUrl, token)
          .then((apiUser) => {
            sessionStorage.setItem("boletas.auth.user", JSON.stringify(apiUser));
            renderUser(apiUser);
            renderAdminOnly(apiUser);
            void loadAssignableUsers();
            void loadEvents();
          })
          .catch(() => {
            redirectToLogin();
          });
      }
    } catch {
      redirectToLogin();
    }
  </script>

