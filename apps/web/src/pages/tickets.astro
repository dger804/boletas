              data-responsible-mail
            ></a>
          </div>

          <div class="flex gap-3">
            <NotebookText class="mt-0.5 text-zinc-400" size={17} />
            <div class="min-w-0 flex-1">
              <p class="text-xs font-medium uppercase text-zinc-500">Notas</p>
              <p class="mt-1 whitespace-pre-wrap break-words text-sm text-zinc-700" data-responsible-notes>
                Sin notas registradas
              </p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
