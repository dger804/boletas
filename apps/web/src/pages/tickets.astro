---
import {
  CalendarDays,
  LogOut,
  Plus,
  RefreshCw,
  ShieldCheck,
  Ticket
} from "lucide-astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? "/api";
const authMeUrl = `${apiBase}/auth/me`;
const eventsUrl = `${apiBase}/events`;
const ticketsUrl = `${apiBase}/tickets`;
---

<BaseLayout title="Boletas | Inventario">
  <span
    hidden
    data-auth-me-url={authMeUrl}
    data-events-url={eventsUrl}
    data-tickets-url={ticketsUrl}
  ></span>
  <script>
    type EventStatus = "draft" | "active" | "closed";
    type PaymentMethod = "cash" | "transfer";
    type TicketStatus =
      | "assigned"
      | "available"
      | "paid"
      | "reserved"
      | "sold"
      | "used"
      | "void";
    type UserRole = "regular" | "supervisor" | "admin";

    interface StoredUser {
      id: string;
      email: string;
      name: string;
      role: UserRole;
    }

    interface EventRecord {
      id: string;
      name: string;
      date: string;
      venue: string;
      status: EventStatus;
      expectedAttendees: number;
      createdAt: string;
    }

    interface TicketRecord {
      id: string;
      eventId: string;
      code: string;
      price: number;
      status: TicketStatus;
      distributorId?: string;
      distributorName?: string;
      recipientName?: string;
      buyerName?: string;
      buyerPhone?: string;
      paymentMethod?: PaymentMethod;
      soldAt?: string;
      paidAt?: string;
      usedAt?: string;
      checkedInBy?: string;
      capitalizationAmount: number;
      notes?: string;
      createdAt: string;
    }

    interface AuthMeResponse {
      user?: StoredUser;
    }

    const allowedRoles = new Set(["regular", "supervisor", "admin"]);
    const allowedEventStatuses = new Set(["draft", "active", "closed"]);
    const allowedTicketStatuses = new Set([
      "assigned",
      "available",
      "paid",
      "reserved",
      "sold",
      "used",
      "void"
    ]);
    const allowedPaymentMethods = new Set(["cash", "transfer"]);
    const roleLabels: Record<UserRole, string> = {
      admin: "Admin",
      regular: "Regular",
      supervisor: "Supervisor"
    };
    const ticketStatusLabels: Record<TicketStatus, string> = {
      assigned: "Asignada",
      available: "Disponible",
      paid: "Pagada",
      reserved: "Reservada",
      sold: "Vendida",
      used: "Usada",
      void: "Bloqueada"
    };
    const ticketStatusClasses: Record<TicketStatus, string> = {
      assigned: "bg-zinc-100 text-zinc-700",
      available: "bg-sky-50 text-sky-700",
      paid: "bg-emerald-50 text-emerald-700",
      reserved: "bg-violet-50 text-violet-700",
      sold: "bg-amber-50 text-amber-700",
      used: "bg-indigo-50 text-indigo-700",
      void: "bg-rose-50 text-rose-700"
    };
    const paymentMethodLabels: Record<PaymentMethod, string> = {
      cash: "Efectivo",
      transfer: "Transferencia"
    };

    let authToken = "";
    let currentEvents: EventRecord[] = [];
    let currentTickets: TicketRecord[] = [];
    let selectedTicketId = "";
    let selectedEventId = new URLSearchParams(window.location.search)
      .get("eventId")
      ?.trim() ?? "";
    const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);
    const money = new Intl.NumberFormat("es-CO", {
      currency: "COP",
      maximumFractionDigits: 0,
      style: "currency"
    });

    const resolveApiUrl = (url: string | null | undefined) => {
      if (!url) {
        return null;
      }

      if (url.startsWith("/api") && localHosts.has(window.location.hostname)) {
        return `http://localhost:3000${url}`;
      }

      return url;
    };

    const clearSession = () => {
      sessionStorage.removeItem("boletas.auth.token");
      sessionStorage.removeItem("boletas.auth.expiresAt");
      sessionStorage.removeItem("boletas.auth.user");
    };

    const redirectToLogin = () => {
      clearSession();
      window.location.replace("/login");
    };

    const getConfig = () => {
      const config = document.querySelector<HTMLElement>("[data-auth-me-url]");

      return {
        authMeUrl: resolveApiUrl(config?.dataset.authMeUrl),
        eventsUrl: resolveApiUrl(config?.dataset.eventsUrl),
        ticketsUrl: resolveApiUrl(config?.dataset.ticketsUrl)
      };
    };

    const isStoredUser = (value: unknown): value is StoredUser => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const user = value as Partial<StoredUser>;

      return (
        typeof user.id === "string" &&
        typeof user.email === "string" &&
        typeof user.name === "string" &&
        typeof user.role === "string" &&
        allowedRoles.has(user.role)
      );
    };

    const isEventRecord = (value: unknown): value is EventRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const event = value as Partial<EventRecord>;

      return (
        typeof event.id === "string" &&
        typeof event.name === "string" &&
        typeof event.date === "string" &&
        typeof event.venue === "string" &&
        typeof event.status === "string" &&
        allowedEventStatuses.has(event.status) &&
        typeof event.expectedAttendees === "number" &&
        typeof event.createdAt === "string"
      );
    };

    const isTicketRecord = (value: unknown): value is TicketRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const ticket = value as Partial<TicketRecord>;
      const paymentMethodIsValid =
        typeof ticket.paymentMethod === "undefined" ||
        (typeof ticket.paymentMethod === "string" &&
          allowedPaymentMethods.has(ticket.paymentMethod));
      const distributorNameIsValid =
        typeof ticket.distributorName === "undefined" ||
        typeof ticket.distributorName === "string";

      return (
        typeof ticket.id === "string" &&
        typeof ticket.eventId === "string" &&
        typeof ticket.code === "string" &&
        typeof ticket.price === "number" &&
        typeof ticket.status === "string" &&
        allowedTicketStatuses.has(ticket.status) &&
        typeof ticket.capitalizationAmount === "number" &&
        typeof ticket.createdAt === "string" &&
        distributorNameIsValid &&
        paymentMethodIsValid
      );
    };

    const readStoredUser = (): StoredUser | null => {
      const storedUser = sessionStorage.getItem("boletas.auth.user");

      if (!storedUser) {
        return null;
      }

      try {
        const parsed = JSON.parse(storedUser) as unknown;

        return isStoredUser(parsed) ? parsed : null;
      } catch {
        return null;
      }
    };

    const isExpired = (expiresAt: string | null) => {
      const expiresAtMs = expiresAt ? Date.parse(expiresAt) : Number.NaN;

      return !Number.isFinite(expiresAtMs) || expiresAtMs <= Date.now();
    };

    const whenReady = (callback: () => void) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", callback, { once: true });
      } else {
        callback();
      }
    };

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");

    const renderUser = (user: StoredUser) => {
      document.querySelectorAll("[data-auth-user-name]").forEach((element) => {
        element.textContent = user.name;
      });

      document.querySelectorAll("[data-auth-user-email]").forEach((element) => {
        element.textContent = user.email;
      });

      document.querySelectorAll("[data-auth-user-role]").forEach((element) => {
        element.textContent = roleLabels[user.role];
      });
    };

    const renderAdminOnly = (user: StoredUser) => {
      document.querySelectorAll<HTMLElement>("[data-admin-only]").forEach((element) => {
        element.classList.toggle("hidden", user.role !== "admin");
      });
    };

    const bindLogout = () => {
      document.querySelectorAll("[data-logout-button]").forEach((button) => {
        button.addEventListener("click", () => {
          clearSession();
          window.location.replace("/login");
        });
      });
    };

    const setStatus = (message: string, tone: "neutral" | "success" | "error" = "neutral") => {
      const element = document.querySelector<HTMLElement>("[data-tickets-status]");

      if (!element) {
        return;
      }

      const toneClasses = {
        error: "border-rose-200 bg-rose-50 text-rose-700",
        neutral: "border-zinc-200 bg-white text-zinc-600",
        success: "border-emerald-200 bg-emerald-50 text-emerald-700"
      };

      element.className = `rounded-md border px-3 py-2 text-sm ${toneClasses[tone]}`;
      element.textContent = message;
      element.classList.remove("hidden");
    };

    const validateSession = async (url: string, token: string) => {
      const response = await fetch(url, {
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error(`Auth session rejected with ${response.status}`);
      }

      const payload = (await response.json()) as AuthMeResponse;

      if (!isStoredUser(payload.user)) {
        throw new Error("Auth session response did not include a valid user.");
      }

      return payload.user;
    };

    const requestJson = async <T,>(url: string, options: RequestInit = {}) => {
      const response = await fetch(url, {
        ...options,
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${authToken}`,
          ...(options.body ? { "Content-Type": "application/json" } : {}),
          ...options.headers
        }
      });

      if (response.status === 401 || response.status === 403) {
        redirectToLogin();
      }

      if (!response.ok) {
        let message = `Solicitud rechazada con estado ${response.status}.`;

        try {
          const payload = (await response.json()) as { message?: string };

          if (payload.message) {
            message = payload.message;
          }
        } catch {
          // Keep the generic message.
        }

        throw new Error(message);
      }

      return (await response.json()) as T;
    };

    const formatDate = (value?: string) => {
      if (!value) {
        return "Sin registro";
      }

      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return "Sin registro";
      }

      return new Intl.DateTimeFormat("es-CO", {
        dateStyle: "medium",
        timeStyle: "short"
      }).format(date);
    };

    const getSelectedEvent = () =>
      currentEvents.find((event) => event.id === selectedEventId) ?? currentEvents[0] ?? null;

    const isSaleableTicket = (ticket: TicketRecord) =>
      ["assigned", "available", "reserved"].includes(ticket.status);

    const getSelectedTicket = () =>
      currentTickets.find((ticket) => ticket.id === selectedTicketId) ?? null;

    const updateSelectedEvent = (eventId: string) => {
      selectedEventId = eventId;
      const selector = document.querySelector<HTMLSelectElement>("[data-event-selector]");

      if (selector) {
        selector.value = selectedEventId;
      }

      const query = new URLSearchParams(window.location.search);
      query.set("eventId", selectedEventId);
      window.history.replaceState(null, "", `${window.location.pathname}?${query.toString()}`);
    };

    const renderEventOptions = () => {
      const selector = document.querySelector<HTMLSelectElement>("[data-event-selector]");
      const batchEventName = document.querySelector<HTMLElement>("[data-batch-event-name]");

      if (!selector) {
        return;
      }

      if (currentEvents.length === 0) {
        selector.innerHTML = `<option value="">Sin eventos</option>`;
        selector.setAttribute("disabled", "true");
        if (batchEventName) {
          batchEventName.textContent = "Selecciona un evento";
        }
        return;
      }

      if (!currentEvents.some((event) => event.id === selectedEventId)) {
        selectedEventId = currentEvents[0].id;
      }

      selector.removeAttribute("disabled");
      selector.innerHTML = currentEvents
        .map(
          (event) =>
            `<option value="${escapeHtml(event.id)}"${event.id === selectedEventId ? " selected" : ""}>${escapeHtml(event.name)}</option>`
        )
        .join("");

      if (batchEventName) {
        batchEventName.textContent = getSelectedEvent()?.name ?? "Selecciona un evento";
      }
    };

    const updateSalePanel = () => {
      const ticket = getSelectedTicket();
      const selectedCode = document.querySelector<HTMLElement>("[data-sale-ticket-code]");
      const submitButton = document.querySelector<HTMLButtonElement>("[data-register-sale-submit]");
      const form = document.querySelector<HTMLFormElement>("[data-register-sale-form]");

      if (selectedCode) {
        selectedCode.textContent = ticket
          ? `Boleta ${ticket.code}`
          : "Selecciona una boleta";
      }

      if (submitButton) {
        submitButton.disabled = !ticket || !isSaleableTicket(ticket);
      }

      if (!form || !ticket) {
        return;
      }

      const amount = form.querySelector<HTMLInputElement>('[name="amount"]');
      const buyerName = form.querySelector<HTMLInputElement>('[name="buyerName"]');
      const capitalizationAmount = form.querySelector<HTMLInputElement>(
        '[name="capitalizationAmount"]'
      );

      if (amount) {
        amount.value = String(ticket.price);
      }

      if (buyerName) {
        buyerName.value = ticket.recipientName ?? "";
      }

      if (capitalizationAmount) {
        capitalizationAmount.value = String(ticket.capitalizationAmount);
      }
    };

    const selectTicketForSale = (ticketId: string) => {
      const ticket = currentTickets.find((item) => item.id === ticketId);

      if (!ticket) {
        setStatus("No se encontro la boleta seleccionada.", "error");
        return;
      }

      if (!isSaleableTicket(ticket)) {
        setStatus("Esta boleta ya no permite registrar venta.", "error");
        return;
      }

      selectedTicketId = ticket.id;
      updateSalePanel();
      setStatus(`Venta preparada para ${ticket.code}.`);
    };

    const renderTickets = (tickets: TicketRecord[]) => {
      const body = document.querySelector<HTMLElement>("[data-tickets-body]");
      const count = document.querySelector<HTMLElement>("[data-tickets-count]");
      const total = document.querySelector<HTMLElement>("[data-tickets-total]");
      const capitalization = document.querySelector<HTMLElement>("[data-tickets-capitalization]");

      if (count) {
        count.textContent = `${tickets.length}`;
      }

      if (total) {
        total.textContent = money.format(
          tickets.reduce((sum, ticket) => sum + ticket.price, 0)
        );
      }

      if (capitalization) {
        capitalization.textContent = money.format(
          tickets.reduce((sum, ticket) => sum + ticket.capitalizationAmount, 0)
        );
      }

      if (!body) {
        return;
      }

      if (tickets.length === 0) {
        body.innerHTML = `
          <tr>
            <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="9">
              Sin boletas registradas para este evento
            </td>
          </tr>
        `;
        return;
      }

      body.innerHTML = tickets
        .map((ticket) => {
          const statusLabel = ticketStatusLabels[ticket.status];
          const statusClass = ticketStatusClasses[ticket.status];
          const holder =
            ticket.buyerName ??
            ticket.recipientName ??
            "Sin titular";
          const responsible =
            ticket.distributorName ??
            (ticket.distributorId ? "Responsable asignado" : "Sin responsable");
          const paymentMethod = ticket.paymentMethod
            ? paymentMethodLabels[ticket.paymentMethod]
            : "Sin pago";
          const saleButton = isSaleableTicket(ticket)
            ? `
              <button
                class="inline-flex h-9 items-center rounded-md bg-zinc-950 px-3 text-sm font-medium text-white hover:bg-zinc-800"
                data-select-ticket-sale="${escapeHtml(ticket.id)}"
                type="button"
              >
                Venta
              </button>
            `
            : `<span class="text-xs text-zinc-400">No disponible</span>`;

          return `
            <tr class="align-top hover:bg-zinc-50">
              <td class="whitespace-nowrap px-4 py-3 font-medium text-zinc-950">
                ${escapeHtml(ticket.code)}
              </td>
              <td class="min-w-56 px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(responsible)}
              </td>
              <td class="min-w-56 px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(holder)}
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <span class="rounded-md px-2 py-1 text-xs font-medium ${statusClass}">
                  ${escapeHtml(statusLabel)}
                </span>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(paymentMethod)}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right text-sm font-semibold text-zinc-950">
                ${escapeHtml(money.format(ticket.price))}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right text-sm text-zinc-600">
                ${escapeHtml(money.format(ticket.capitalizationAmount))}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(formatDate(ticket.createdAt))}
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                ${saleButton}
              </td>
            </tr>
          `;
        })
        .join("");
    };

    const loadTickets = async () => {
      const { ticketsUrl } = getConfig();

      if (!ticketsUrl) {
        setStatus("No se encontro la ruta de boletas.", "error");
        return;
      }

      if (!selectedEventId) {
        currentTickets = [];
        selectedTicketId = "";
        renderTickets([]);
        updateSalePanel();
        setStatus("Selecciona un evento para ver sus boletas.");
        return;
      }

      setStatus("Cargando boletas.");

      try {
        const url = `${ticketsUrl}?eventId=${encodeURIComponent(selectedEventId)}`;
        const payload = await requestJson<unknown[]>(url);
        const tickets = Array.isArray(payload) ? payload.filter(isTicketRecord) : [];

        currentTickets = tickets;
        if (!currentTickets.some((ticket) => ticket.id === selectedTicketId && isSaleableTicket(ticket))) {
          selectedTicketId = "";
        }
        renderTickets(tickets);
        updateSalePanel();
        setStatus("Boletas actualizadas.", "success");
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible cargar boletas.",
          "error"
        );
      }
    };

    const loadEvents = async () => {
      const { eventsUrl } = getConfig();

      if (!eventsUrl) {
        setStatus("No se encontro la ruta de eventos.", "error");
        return;
      }

      setStatus("Cargando eventos.");

      try {
        const payload = await requestJson<unknown[]>(eventsUrl);
        currentEvents = Array.isArray(payload) ? payload.filter(isEventRecord) : [];
        renderEventOptions();

        if (selectedEventId) {
          await loadTickets();
        } else {
          currentTickets = [];
          selectedTicketId = "";
          renderTickets([]);
          updateSalePanel();
          setStatus("No hay eventos para consultar.");
        }
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : "No fue posible cargar eventos.",
          "error"
        );
      }
    };

    const bindTicketActions = () => {
      document.querySelector("[data-refresh-tickets]")?.addEventListener("click", () => {
        void loadEvents();
      });

      document
        .querySelector<HTMLSelectElement>("[data-event-selector]")
        ?.addEventListener("change", (event) => {
          const target = event.currentTarget as HTMLSelectElement;
          updateSelectedEvent(target.value);
          void loadTickets();
        });

      document.querySelector("[data-tickets-body]")?.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;
        const saleButton = target.closest<HTMLButtonElement>("[data-select-ticket-sale]");

        if (!saleButton?.dataset.selectTicketSale) {
          return;
        }

        selectTicketForSale(saleButton.dataset.selectTicketSale);
      });
    };

    const bindCreateBatchForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-create-ticket-batch-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { eventsUrl } = getConfig();
        const selectedEvent = getSelectedEvent();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!eventsUrl || !selectedEvent) {
          setStatus("Selecciona un evento antes de crear boletas.", "error");
          return;
        }

        const formData = new FormData(form);
        const payload = {
          capitalizationAmount: Number(formData.get("capitalizationAmount") ?? 0),
          codePrefix: String(formData.get("codePrefix") ?? "").trim() || undefined,
          price: Number(formData.get("price") ?? 0),
          quantity: Number(formData.get("quantity") ?? 0)
        };

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<TicketRecord[]>(
            `${eventsUrl}/${encodeURIComponent(selectedEvent.id)}/tickets/batch`,
            {
              body: JSON.stringify(payload),
              method: "POST"
            }
          );
          form.reset();
          setStatus("Lote de boletas creado.", "success");
          await loadTickets();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible crear el lote.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
        }
      });
    };

    const bindRegisterSaleForm = () => {
      const form = document.querySelector<HTMLFormElement>("[data-register-sale-form]");

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const { ticketsUrl } = getConfig();
        const ticket = getSelectedTicket();
        const submitButton = form.querySelector<HTMLButtonElement>("button[type='submit']");

        if (!ticketsUrl || !ticket) {
          setStatus("Selecciona una boleta antes de registrar la venta.", "error");
          return;
        }

        if (!isSaleableTicket(ticket)) {
          setStatus("Esta boleta ya no permite registrar venta.", "error");
          return;
        }

        const formData = new FormData(form);
        const buyerPhone = String(formData.get("buyerPhone") ?? "").trim();
        const evidenceUrl = String(formData.get("evidenceUrl") ?? "").trim();
        const notes = String(formData.get("notes") ?? "").trim();
        const reference = String(formData.get("reference") ?? "").trim();
        const payload = {
          amount: Number(formData.get("amount") ?? ticket.price),
          buyerName: String(formData.get("buyerName") ?? "").trim(),
          capitalizationAmount: Number(
            formData.get("capitalizationAmount") ?? ticket.capitalizationAmount
          ),
          method: String(formData.get("method") ?? "cash"),
          ...(buyerPhone ? { buyerPhone } : {}),
          ...(evidenceUrl ? { evidenceUrl } : {}),
          ...(notes ? { notes } : {}),
          ...(reference ? { reference } : {})
        };

        submitButton?.setAttribute("disabled", "true");

        try {
          await requestJson<{ payment: unknown; ticket: TicketRecord }>(
            `${ticketsUrl}/${encodeURIComponent(ticket.id)}/sale`,
            {
              body: JSON.stringify(payload),
              method: "PATCH"
            }
          );
          form.reset();
          selectedTicketId = "";
          setStatus("Venta registrada. El pago queda pendiente de validacion.", "success");
          await loadTickets();
        } catch (error) {
          setStatus(
            error instanceof Error ? error.message : "No fue posible registrar la venta.",
            "error"
          );
        } finally {
          submitButton?.removeAttribute("disabled");
          updateSalePanel();
        }
      });
    };

    try {
      const { authMeUrl } = getConfig();
      const token = sessionStorage.getItem("boletas.auth.token");
      const expiresAt = sessionStorage.getItem("boletas.auth.expiresAt");
      const user = readStoredUser();

      if (!authMeUrl || !token || isExpired(expiresAt) || !user) {
        redirectToLogin();
      } else {
        authToken = token;
        whenReady(() => {
          renderUser(user);
          bindLogout();
          bindTicketActions();
          bindCreateBatchForm();
          bindRegisterSaleForm();
        });

        validateSession(authMeUrl, token)
          .then((apiUser) => {
            sessionStorage.setItem("boletas.auth.user", JSON.stringify(apiUser));
            renderUser(apiUser);
            renderAdminOnly(apiUser);
            void loadEvents();
          })
          .catch(() => {
            redirectToLogin();
          });
      }
    } catch {
      redirectToLogin();
    }
  </script>

  <div class="grid min-h-screen lg:grid-cols-[240px_1fr]">
    <aside class="border-b border-zinc-200 bg-white px-4 py-4 lg:border-b-0 lg:border-r">
      <div class="flex h-full flex-col gap-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-950 text-white">
            <Ticket size={20} />
          </span>
          <div>
            <p class="text-sm font-semibold text-zinc-950">Boletas</p>
            <p class="text-xs text-zinc-500">Inventario</p>
          </div>
        </div>

        <nav class="grid gap-1 text-sm">
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/dashboard">
            Tablero
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-admin-only href="/users">
            Usuarios
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/events">
            Eventos
          </a>
          <a class="rounded-md bg-zinc-950 px-3 py-2 font-medium text-white" href="/tickets">
            Boletas
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="#">
            Pagos
          </a>
        </nav>

        <div class="mt-auto rounded-lg border border-zinc-200 bg-zinc-50 p-3">
          <p class="text-xs font-medium text-zinc-500">Sesion</p>
          <p class="mt-1 truncate text-sm font-semibold text-zinc-950" data-auth-user-name>
            Usuario
          </p>
          <p class="mt-1 truncate text-xs text-zinc-500" data-auth-user-email>
            usuario@dominio.com
          </p>
        </div>
      </div>
    </aside>

    <main class="min-w-0">
      <header class="border-b border-zinc-200 bg-white px-4 py-4 sm:px-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <div class="flex items-center gap-2 text-xs font-medium text-zinc-500">
              <CalendarDays size={14} />
              <span>Inventario por evento</span>
            </div>
            <h1 class="mt-2 text-2xl font-semibold text-zinc-950">
              Boletas
            </h1>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <select
              class="h-10 min-w-64 rounded-md border border-zinc-200 bg-white px-3 text-sm text-zinc-700 outline-none focus:border-zinc-500 disabled:bg-zinc-100"
              data-event-selector
            >
              <option value="">Cargando eventos</option>
            </select>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-refresh-tickets
              title="Actualizar"
              type="button"
            >
              <RefreshCw size={17} />
              Actualizar
            </button>
            <div class="flex h-10 items-center gap-2 rounded-md border border-zinc-200 bg-white px-3">
              <ShieldCheck class="text-emerald-600" size={17} />
              <div class="hidden leading-tight sm:block">
                <p class="max-w-36 truncate text-xs font-semibold text-zinc-950" data-auth-user-name>
                  Usuario
                </p>
                <p class="text-[11px] uppercase text-zinc-500" data-auth-user-role>
                  Admin
                </p>
              </div>
            </div>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-logout-button
              title="Cerrar sesion"
              type="button"
            >
              <LogOut size={17} />
              Salir
            </button>
          </div>
        </div>
      </header>

      <div class="space-y-6 p-4 sm:p-6">
        <p class="hidden rounded-md border px-3 py-2 text-sm" data-tickets-status></p>

        <section class="grid gap-4 md:grid-cols-3">
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Boletas</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-tickets-count>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Valor total</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-tickets-total>$0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Capitalizacion</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-tickets-capitalization>$0</p>
          </div>
        </section>

        <section class="grid gap-6 xl:grid-cols-[360px_1fr]">
          <div class="space-y-6">
            <section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
              <div class="flex items-center gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-emerald-600 text-white">
                  <Ticket size={18} />
                </span>
                <div>
                  <h2 class="text-sm font-semibold text-zinc-950">Registrar venta</h2>
                  <p class="mt-1 text-xs text-zinc-500" data-sale-ticket-code>Selecciona una boleta</p>
                </div>
              </div>

              <form class="mt-5 grid gap-4" data-register-sale-form>
                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">Comprador</span>
                  <input
                    class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                    maxlength="120"
                    name="buyerName"
                    required
                    type="text"
                  />
                </label>

                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">Telefono</span>
                  <input
                    class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                    maxlength="40"
                    name="buyerPhone"
                    type="tel"
                  />
                </label>

                <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                  <label class="grid gap-2">
                    <span class="text-sm font-medium text-zinc-700">Metodo</span>
                    <select
                      class="h-10 rounded-md border border-zinc-200 bg-white px-3 text-sm outline-none focus:border-zinc-500"
                      name="method"
                    >
                      <option value="transfer">Transferencia</option>
                      <option value="cash">Efectivo</option>
                    </select>
                  </label>

                  <label class="grid gap-2">
                    <span class="text-sm font-medium text-zinc-700">Valor recibido</span>
                    <input
                      class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                      min="0"
                      name="amount"
                      required
                      step="1000"
                      type="number"
                    />
                  </label>
                </div>

                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">Capitalizacion</span>
                  <input
                    class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                    min="0"
                    name="capitalizationAmount"
                    step="1000"
                    type="number"
                  />
                </label>

                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">Referencia</span>
                  <input
                    class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                    maxlength="120"
                    name="reference"
                    placeholder="Banco, caja o comprobante"
                    type="text"
                  />
                </label>

                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">URL evidencia</span>
                  <input
                    class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                    maxlength="500"
                    name="evidenceUrl"
                    placeholder="https://..."
                    type="url"
                  />
                </label>

                <label class="grid gap-2">
                  <span class="text-sm font-medium text-zinc-700">Notas</span>
                  <textarea
                    class="min-h-20 rounded-md border border-zinc-200 px-3 py-2 text-sm outline-none focus:border-zinc-500"
                    maxlength="500"
                    name="notes"
                  ></textarea>
                </label>

                <button
                  class="inline-flex h-10 items-center justify-center rounded-md bg-zinc-950 px-4 text-sm font-semibold text-white hover:bg-zinc-800 disabled:cursor-not-allowed disabled:opacity-60"
                  data-register-sale-submit
                  disabled
                  type="submit"
                >
                  Registrar venta
                </button>
              </form>
            </section>

            <section class="hidden rounded-lg border border-zinc-200 bg-white p-4 shadow-sm" data-admin-only>
            <div class="flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-zinc-950 text-white">
                <Plus size={18} />
              </span>
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Nuevo lote</h2>
                <p class="mt-1 text-xs text-zinc-500" data-batch-event-name>Selecciona un evento</p>
              </div>
            </div>

            <form class="mt-5 grid gap-4" data-create-ticket-batch-form>
              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Cantidad</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                  max="5000"
                  min="1"
                  name="quantity"
                  required
                  type="number"
                  value="10"
                />
              </label>

              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Valor boleta</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                  min="0"
                  name="price"
                  required
                  step="1000"
                  type="number"
                  value="90000"
                />
              </label>

              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Capitalizacion por boleta</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 px-3 text-sm outline-none focus:border-zinc-500"
                  min="0"
                  name="capitalizationAmount"
                  step="1000"
                  type="number"
                  value="0"
                />
              </label>

              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Prefijo</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 px-3 text-sm uppercase outline-none focus:border-zinc-500"
                  maxlength="12"
                  name="codePrefix"
                  placeholder="GEN"
                  type="text"
                />
              </label>

              <button
                class="inline-flex h-10 items-center justify-center rounded-md bg-zinc-950 px-4 text-sm font-semibold text-white hover:bg-zinc-800 disabled:cursor-not-allowed disabled:opacity-60"
                type="submit"
              >
                Crear lote
              </button>
            </form>
            </section>
          </div>

          <section class="rounded-lg border border-zinc-200 bg-white shadow-sm">
            <div class="flex flex-col gap-3 border-b border-zinc-200 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Inventario</h2>
                <p class="mt-1 text-xs text-zinc-500">Boletas del evento seleccionado</p>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-zinc-100 text-left">
                <thead class="bg-zinc-50 text-xs uppercase text-zinc-500">
                  <tr>
                    <th class="px-4 py-3 font-medium">Codigo</th>
                    <th class="px-4 py-3 font-medium">Responsable</th>
                    <th class="px-4 py-3 font-medium">Titular</th>
                    <th class="px-4 py-3 font-medium">Estado</th>
                    <th class="px-4 py-3 font-medium">Pago</th>
                    <th class="px-4 py-3 text-right font-medium">Valor</th>
                    <th class="px-4 py-3 text-right font-medium">Capitalizacion</th>
                    <th class="px-4 py-3 font-medium">Creada</th>
                    <th class="px-4 py-3 text-right font-medium">Accion</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 bg-white" data-tickets-body>
                  <tr>
                    <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="9">
                      Cargando boletas
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
