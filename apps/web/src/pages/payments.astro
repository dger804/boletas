        <section class="grid gap-4 md:grid-cols-4">
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Evidencias</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-payments-count>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Pendientes</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-payments-pending>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Aprobadas</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-payments-approved>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Recaudo aprobado</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-payments-total>$0</p>
          </div>
        </section>

        <section class="grid gap-6 xl:grid-cols-[360px_1fr]">
          <section class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-zinc-950 text-white">
