              </label>

              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Revisado por</span>
                <input
                  class="h-10 rounded-md border border-zinc-200 bg-zinc-50 px-3 text-sm text-zinc-600 outline-none focus:border-zinc-500"
                  maxlength="120"
                  name="reviewedBy"
                  readonly
                  required
                  type="text"
                />
              </label>

              <label class="grid gap-2">
                <span class="text-sm font-medium text-zinc-700">Notas</span>
                <textarea
                  class="min-h-24 rounded-md border border-zinc-200 px-3 py-2 text-sm outline-none focus:border-zinc-500"
                  maxlength="500"
                  name="notes"
                ></textarea>
              </label>

              <button
                class="inline-flex h-10 items-center justify-center rounded-md bg-zinc-950 px-4 text-sm font-semibold text-white hover:bg-zinc-800 disabled:cursor-not-allowed disabled:opacity-60"
                data-review-payment-submit
                disabled
                type="submit"
              >
                Guardar validacion
              </button>
            </form>
          </section>

          <section class="rounded-lg border border-zinc-200 bg-white shadow-sm">
            <div class="flex flex-col gap-3 border-b border-zinc-200 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Evidencias</h2>
                <p class="mt-1 text-xs text-zinc-500">Pagos reportados del evento seleccionado</p>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-zinc-100 text-left">
                <thead class="bg-zinc-50 text-xs uppercase text-zinc-500">
                  <tr>
                    <th class="px-4 py-3 font-medium">Boleta</th>
                    <th class="px-4 py-3 font-medium">Comprador</th>
                    <th class="px-4 py-3 font-medium">Metodo</th>
                    <th class="px-4 py-3 font-medium">Estado</th>
                    <th class="px-4 py-3 text-right font-medium">Valor</th>
                    <th class="px-4 py-3 text-right font-medium">Capitalizacion</th>
                    <th class="px-4 py-3 font-medium">Soporte</th>
                    <th class="px-4 py-3 font-medium">Recibido</th>
                    <th class="px-4 py-3 text-right font-medium">Accion</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 bg-white" data-payments-body>
                  <tr>
                    <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="9">
