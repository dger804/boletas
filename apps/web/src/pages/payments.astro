          <a class="hidden rounded-md bg-zinc-950 px-3 py-2 font-medium text-white" data-manager-only href="/payments">
            Pagos
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-manager-only href="/closeout">
            Corte
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-manager-only href="/audit">
