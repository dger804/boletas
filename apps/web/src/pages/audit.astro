---
import {
  Activity,
  CalendarDays,
  LogOut,
  RefreshCw,
  Search,
  ShieldCheck,
  Ticket
} from "lucide-astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? "/api";
const auditUrl = `${apiBase}/audit`;
const authMeUrl = `${apiBase}/auth/me`;
const eventsUrl = `${apiBase}/events`;
---

<BaseLayout title="Auditoria | Boletas">
  <span
    hidden
    data-audit-url={auditUrl}
    data-auth-me-url={authMeUrl}
    data-events-url={eventsUrl}
  ></span>
  <script>
    type EventStatus = "draft" | "active" | "closed";
    type UserRole = "regular" | "supervisor" | "admin";
    type AuditLogMetadata = Record<string, string | number | boolean | null>;

    interface StoredUser {
      id: string;
      email: string;
      name: string;
      role: UserRole;
    }

    interface AuthMeResponse {
      user?: StoredUser;
    }

    interface EventRecord {
      id: string;
      name: string;
      date: string;
      venue: string;
      status: EventStatus;
      expectedAttendees: number;
      createdAt: string;
    }

    interface AuditLogRecord {
      id: string;
      eventId?: string;
      entityType: string;
      entityId: string;
      action: string;
      fromStatus?: string;
      toStatus?: string;
      actor?: string;
      metadata?: AuditLogMetadata;
      createdAt: string;
    }

    interface AuditResponse {
      logs?: AuditLogRecord[];
    }

    const allowedRoles = new Set(["regular", "supervisor", "admin"]);
    const allowedEventStatuses = new Set(["draft", "active", "closed"]);
    const managerRoles = new Set(["supervisor", "admin"]);
    const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);
    const roleLabels: Record<UserRole, string> = {
      admin: "Admin",
      regular: "Regular",
      supervisor: "Supervisor"
    };
    const actionLabels: Record<string, string> = {
      "distributor.create": "Responsable creado",
      "event.create": "Evento creado",
      "event.update": "Evento actualizado",
      "payment.verify": "Pago validado",
      "ticket.assign": "Boleta asignada",
      "ticket.batch_create": "Lote de boletas",
      "ticket.check_in": "Ingreso registrado",
      "ticket.sale": "Venta registrada"
    };
    const entityLabels: Record<string, string> = {
      distributor: "Responsable",
      event: "Evento",
      payment_evidence: "Evidencia",
      ticket: "Boleta"
    };

    let authToken = "";
    let currentEvents: EventRecord[] = [];
    let currentLogs: AuditLogRecord[] = [];
    let selectedEventId = new URLSearchParams(window.location.search)
      .get("eventId")
      ?.trim() ?? "";

    const resolveApiUrl = (url: string | null | undefined) => {
      if (!url) {
        return null;
      }

      if (url.startsWith("/api") && localHosts.has(window.location.hostname)) {
        return `http://localhost:3000${url}`;
      }

      return url;
    };

    const getConfig = () => {
      const config = document.querySelector<HTMLElement>("[data-auth-me-url]");

      return {
        auditUrl: resolveApiUrl(config?.dataset.auditUrl),
        authMeUrl: resolveApiUrl(config?.dataset.authMeUrl),
        eventsUrl: resolveApiUrl(config?.dataset.eventsUrl)
      };
    };

    const clearSession = () => {
      sessionStorage.removeItem("boletas.auth.token");
      sessionStorage.removeItem("boletas.auth.expiresAt");
      sessionStorage.removeItem("boletas.auth.user");
    };

    const redirectToLogin = () => {
      clearSession();
      window.location.replace("/login?reason=session-expired");
    };

    const isStoredUser = (value: unknown): value is StoredUser => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const user = value as Partial<StoredUser>;

      return (
        typeof user.id === "string" &&
        typeof user.email === "string" &&
        typeof user.name === "string" &&
        typeof user.role === "string" &&
        allowedRoles.has(user.role)
      );
    };

    const isEventRecord = (value: unknown): value is EventRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const event = value as Partial<EventRecord>;

      return (
        typeof event.id === "string" &&
        typeof event.name === "string" &&
        typeof event.date === "string" &&
        typeof event.venue === "string" &&
        typeof event.status === "string" &&
        allowedEventStatuses.has(event.status) &&
        typeof event.expectedAttendees === "number" &&
        typeof event.createdAt === "string"
      );
    };

    const isAuditMetadata = (value: unknown): value is AuditLogMetadata => {
      if (!value || typeof value !== "object" || Array.isArray(value)) {
        return false;
      }

      return Object.values(value).every(
        (item) =>
          typeof item === "string" ||
          typeof item === "number" ||
          typeof item === "boolean" ||
          item === null
      );
    };

    const isAuditLogRecord = (value: unknown): value is AuditLogRecord => {
      if (!value || typeof value !== "object") {
        return false;
      }

      const log = value as Partial<AuditLogRecord>;
      const optionalStringIsValid = (field: unknown) =>
        typeof field === "undefined" || typeof field === "string";

      return (
        typeof log.id === "string" &&
        optionalStringIsValid(log.eventId) &&
        typeof log.entityType === "string" &&
        typeof log.entityId === "string" &&
        typeof log.action === "string" &&
        optionalStringIsValid(log.fromStatus) &&
        optionalStringIsValid(log.toStatus) &&
        optionalStringIsValid(log.actor) &&
        (typeof log.metadata === "undefined" || isAuditMetadata(log.metadata)) &&
        typeof log.createdAt === "string"
      );
    };

    const readStoredUser = (): StoredUser | null => {
      const storedUser = sessionStorage.getItem("boletas.auth.user");

      if (!storedUser) {
        return null;
      }

      try {
        const parsed = JSON.parse(storedUser) as unknown;

        return isStoredUser(parsed) ? parsed : null;
      } catch {
        return null;
      }
    };

    const isExpired = (expiresAt: string | null) => {
      const expiresAtMs = expiresAt ? Date.parse(expiresAt) : Number.NaN;

      return !Number.isFinite(expiresAtMs) || expiresAtMs <= Date.now();
    };

    const whenReady = (callback: () => void) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", callback, { once: true });
      } else {
        callback();
      }
    };

    const escapeHtml = (value: unknown) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");

    const renderUser = (user: StoredUser) => {
      document.querySelectorAll("[data-auth-user-name]").forEach((element) => {
        element.textContent = user.name;
      });

      document.querySelectorAll("[data-auth-user-email]").forEach((element) => {
        element.textContent = user.email;
      });

      document.querySelectorAll("[data-auth-user-role]").forEach((element) => {
        element.textContent = roleLabels[user.role];
      });
    };

    const renderRoleNavigation = (user: StoredUser) => {
      const setRoleElementVisibility = (element: HTMLElement, visible: boolean) => {
        element.classList.toggle("hidden", !visible);

        const displayClass = element.dataset.roleDisplay;

        if (displayClass) {
          element.classList.toggle(displayClass, visible);
        }
      };

      document.querySelectorAll<HTMLElement>("[data-admin-only]").forEach((element) => {
        setRoleElementVisibility(element, user.role === "admin");
      });

      document.querySelectorAll<HTMLElement>("[data-manager-only]").forEach((element) => {
        setRoleElementVisibility(element, managerRoles.has(user.role));
      });
    };

    const bindLogout = () => {
      document.querySelectorAll("[data-logout-button]").forEach((button) => {
        button.addEventListener("click", () => {
          clearSession();
          window.location.replace("/login");
        });
      });
    };

    const setStatus = (message: string, tone: "neutral" | "success" | "error" = "neutral") => {
      const element = document.querySelector<HTMLElement>("[data-audit-status]");

      if (!element) {
        return;
      }

      const toneClasses = {
        error: "border-rose-200 bg-rose-50 text-rose-700",
        neutral: "border-zinc-200 bg-white text-zinc-600",
        success: "border-emerald-200 bg-emerald-50 text-emerald-700"
      };

      element.className = `rounded-md border px-3 py-2 text-sm ${toneClasses[tone]}`;
      element.textContent = message;
      element.classList.remove("hidden");
    };

    const requestJson = async <T,>(url: string) => {
      const response = await fetch(url, {
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${authToken}`
        }
      });

      if (response.status === 401 || response.status === 403) {
        redirectToLogin();
        throw new Error(`Request rejected with ${response.status}`);
      }

      if (!response.ok) {
        throw new Error(`Request failed with ${response.status}`);
      }

      return (await response.json()) as T;
    };

    const validateSession = async (url: string, token: string) => {
      const response = await fetch(url, {
        headers: {
          Accept: "application/json",
          Authorization: `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error(`Auth session rejected with ${response.status}`);
      }

      const payload = (await response.json()) as AuthMeResponse;

      if (!isStoredUser(payload.user)) {
        throw new Error("Auth session response did not include a valid user.");
      }

      return payload.user;
    };

    const getSelectedTake = () => {
      const selector = document.querySelector<HTMLSelectElement>("[data-audit-take]");
      const value = Number(selector?.value ?? "100");

      return Number.isFinite(value) ? value : 100;
    };

    const renderEvents = () => {
      const selector = document.querySelector<HTMLSelectElement>("[data-event-selector]");

      if (!selector) {
        return;
      }

      const options = [
        `<option value="">Todos los eventos</option>`,
        ...currentEvents.map(
          (event) =>
            `<option value="${escapeHtml(event.id)}">${escapeHtml(event.name)}</option>`
        )
      ];

      selector.innerHTML = options.join("");
      selector.value = selectedEventId;
    };

    const selectedEventName = () => {
      if (!selectedEventId) {
        return "Todos los eventos";
      }

      return currentEvents.find((event) => event.id === selectedEventId)?.name ?? selectedEventId;
    };

    const actionLabel = (action: string) => actionLabels[action] ?? action;

    const entityLabel = (entityType: string) => entityLabels[entityType] ?? entityType;

    const formatDateTime = (value: string) => {
      const date = new Date(value);

      if (Number.isNaN(date.getTime())) {
        return value;
      }

      return new Intl.DateTimeFormat("es-CO", {
        dateStyle: "medium",
        timeStyle: "short"
      }).format(date);
    };

    const metadataSummary = (metadata?: AuditLogMetadata) => {
      if (!metadata) {
        return "Sin metadata";
      }

      const entries = Object.entries(metadata)
        .filter(([key]) => key !== "actorId")
        .map(([key, value]) => `${key}: ${String(value ?? "sin valor")}`);

      return entries.length > 0 ? entries.join(" | ") : "Sin metadata visible";
    };

    const statusTransition = (log: AuditLogRecord) => {
      if (log.fromStatus && log.toStatus && log.fromStatus !== log.toStatus) {
        return `${log.fromStatus} -> ${log.toStatus}`;
      }

      return log.toStatus ?? log.fromStatus ?? "Sin cambio";
    };

    const filteredLogs = () => {
      const input = document.querySelector<HTMLInputElement>("[data-audit-search]");
      const query = input?.value.trim().toLowerCase() ?? "";

      if (!query) {
        return currentLogs;
      }

      return currentLogs.filter((log) => {
        const searchable = [
          log.action,
          actionLabel(log.action),
          log.actor,
          log.entityId,
          log.entityType,
          metadataSummary(log.metadata)
        ]
          .join(" ")
          .toLowerCase();

        return searchable.includes(query);
      });
    };

    const renderMetrics = (logs: AuditLogRecord[]) => {
      const lastLog = logs[0];
      const checkIns = logs.filter((log) => log.action === "ticket.check_in").length;
      const paymentReviews = logs.filter((log) => log.action === "payment.verify").length;

      document.querySelectorAll("[data-audit-count]").forEach((element) => {
        element.textContent = `${logs.length}`;
      });

      document.querySelectorAll("[data-audit-check-ins]").forEach((element) => {
        element.textContent = `${checkIns}`;
      });

      document.querySelectorAll("[data-audit-payment-reviews]").forEach((element) => {
        element.textContent = `${paymentReviews}`;
      });

      document.querySelectorAll("[data-audit-last-actor]").forEach((element) => {
        element.textContent = lastLog?.actor ?? "Sin actividad";
      });

      document.querySelectorAll("[data-audit-event-name]").forEach((element) => {
        element.textContent = selectedEventName();
      });
    };

    const renderLogs = () => {
      const body = document.querySelector<HTMLElement>("[data-audit-body]");
      const logs = filteredLogs();

      renderMetrics(logs);

      if (!body) {
        return;
      }

      if (logs.length === 0) {
        body.innerHTML = `
          <tr>
            <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="6">
              No hay auditoria para los filtros actuales
            </td>
          </tr>
        `;
        return;
      }

      body.innerHTML = logs
        .map(
          (log) => `
            <tr class="hover:bg-zinc-50">
              <td class="whitespace-nowrap px-4 py-3 text-sm text-zinc-600">
                ${escapeHtml(formatDateTime(log.createdAt))}
              </td>
              <td class="px-4 py-3">
                <p class="text-sm font-semibold text-zinc-950">${escapeHtml(actionLabel(log.action))}</p>
                <p class="mt-1 text-xs text-zinc-500">${escapeHtml(log.action)}</p>
              </td>
              <td class="px-4 py-3 text-sm text-zinc-700">
                ${escapeHtml(log.actor ?? "Sistema")}
              </td>
              <td class="px-4 py-3 text-sm text-zinc-700">
                <p>${escapeHtml(entityLabel(log.entityType))}</p>
                <p class="mt-1 max-w-44 truncate text-xs text-zinc-500" title="${escapeHtml(log.entityId)}">${escapeHtml(log.entityId)}</p>
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <span class="rounded-md bg-zinc-100 px-2 py-1 text-xs font-medium text-zinc-700">
                  ${escapeHtml(statusTransition(log))}
                </span>
              </td>
              <td class="min-w-64 px-4 py-3 text-xs text-zinc-500">
                ${escapeHtml(metadataSummary(log.metadata))}
              </td>
            </tr>
          `
        )
        .join("");
    };

    const loadEvents = async () => {
      const { eventsUrl } = getConfig();

      if (!eventsUrl) {
        setStatus("No se encontro la URL de eventos.", "error");
        return;
      }

      try {
        const payload = await requestJson<unknown>(eventsUrl);
        currentEvents = Array.isArray(payload) ? payload.filter(isEventRecord) : [];
        renderEvents();
      } catch {
        setStatus("No se pudieron cargar los eventos.", "error");
      }
    };

    const loadAuditLogs = async () => {
      const { auditUrl } = getConfig();

      if (!auditUrl) {
        setStatus("No se encontro la URL de auditoria.", "error");
        return;
      }

      const params = new URLSearchParams();
      params.set("take", String(getSelectedTake()));

      if (selectedEventId) {
        params.set("eventId", selectedEventId);
      }

      try {
        setStatus("Cargando auditoria...", "neutral");
        const payload = await requestJson<AuditResponse>(`${auditUrl}?${params}`);
        currentLogs = Array.isArray(payload.logs)
          ? payload.logs.filter(isAuditLogRecord)
          : [];
        renderLogs();
        setStatus("Auditoria actualizada.", "success");
      } catch {
        currentLogs = [];
        renderLogs();
        setStatus("No se pudo cargar la auditoria.", "error");
      }
    };

    const bindControls = () => {
      document.querySelector("[data-refresh-audit]")?.addEventListener("click", () => {
        void loadAuditLogs();
      });

      document.querySelector("[data-audit-search]")?.addEventListener("input", () => {
        renderLogs();
      });

      document.querySelector("[data-audit-take]")?.addEventListener("change", () => {
        void loadAuditLogs();
      });

      document.querySelector("[data-event-selector]")?.addEventListener("change", (event) => {
        const selector = event.currentTarget as HTMLSelectElement;
        selectedEventId = selector.value;
        void loadAuditLogs();
      });
    };

    try {
      const { authMeUrl } = getConfig();
      const token = sessionStorage.getItem("boletas.auth.token");
      const expiresAt = sessionStorage.getItem("boletas.auth.expiresAt");
      const user = readStoredUser();

      if (!authMeUrl || !token || isExpired(expiresAt) || !user) {
        redirectToLogin();
      } else {
        authToken = token;

        whenReady(() => {
          renderUser(user);
          renderRoleNavigation(user);
          bindLogout();
          bindControls();
        });

        validateSession(authMeUrl, token)
          .then(async (apiUser) => {
            if (!managerRoles.has(apiUser.role)) {
              window.location.replace("/dashboard");
              return;
            }

            sessionStorage.setItem("boletas.auth.user", JSON.stringify(apiUser));
            renderUser(apiUser);
            renderRoleNavigation(apiUser);
            await loadEvents();
            await loadAuditLogs();
          })
          .catch(() => {
            redirectToLogin();
          });
      }
    } catch {
      redirectToLogin();
    }
  </script>

  <div class="grid min-h-screen lg:grid-cols-[240px_1fr]">
    <aside class="border-b border-zinc-200 bg-white px-4 py-4 lg:border-b-0 lg:border-r">
      <div class="flex h-full flex-col gap-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-950 text-white">
            <Ticket size={20} />
          </span>
          <div>
            <p class="text-sm font-semibold text-zinc-950">Boletas</p>
            <p class="text-xs text-zinc-500">Auditoria</p>
          </div>
        </div>

        <nav class="grid gap-1 text-sm">
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/dashboard">
            Tablero
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-admin-only href="/users">
            Usuarios
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/events">
            Eventos
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/tickets">
            Boletas
          </a>
          <a class="rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" href="/check-in">
            Entrada
          </a>
          <a class="hidden rounded-md px-3 py-2 text-zinc-600 hover:bg-zinc-100" data-manager-only href="/payments">
            Pagos
          </a>
          <a class="hidden rounded-md bg-zinc-950 px-3 py-2 font-medium text-white" data-manager-only href="/audit">
            Auditoria
          </a>
        </nav>

        <div class="mt-auto rounded-lg border border-zinc-200 bg-zinc-50 p-3">
          <p class="text-xs font-medium text-zinc-500">Sesion</p>
          <p class="mt-1 truncate text-sm font-semibold text-zinc-950" data-auth-user-name>
            Usuario
          </p>
          <p class="mt-1 truncate text-xs text-zinc-500" data-auth-user-email>
            usuario@dominio.com
          </p>
        </div>
      </div>
    </aside>

    <main class="min-w-0">
      <header class="border-b border-zinc-200 bg-white px-4 py-4 sm:px-6">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <div class="flex items-center gap-2 text-xs font-medium text-zinc-500">
              <CalendarDays size={14} />
              <span data-audit-event-name>Todos los eventos</span>
            </div>
            <h1 class="mt-2 text-2xl font-semibold text-zinc-950">
              Auditoria operativa
            </h1>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            <select
              class="h-10 min-w-64 rounded-md border border-zinc-200 bg-white px-3 text-sm text-zinc-700 outline-none focus:border-zinc-500"
              data-event-selector
            >
              <option value="">Cargando eventos</option>
            </select>
            <select
              class="h-10 rounded-md border border-zinc-200 bg-white px-3 text-sm text-zinc-700 outline-none focus:border-zinc-500"
              data-audit-take
              title="Cantidad de registros"
            >
              <option value="50">50</option>
              <option selected value="100">100</option>
              <option value="200">200</option>
            </select>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-refresh-audit
              title="Actualizar"
              type="button"
            >
              <RefreshCw size={17} />
              Actualizar
            </button>
            <div class="flex h-10 items-center gap-2 rounded-md border border-zinc-200 bg-white px-3">
              <ShieldCheck class="text-emerald-600" size={17} />
              <div class="hidden leading-tight sm:block">
                <p class="max-w-36 truncate text-xs font-semibold text-zinc-950" data-auth-user-name>
                  Usuario
                </p>
                <p class="text-[11px] uppercase text-zinc-500" data-auth-user-role>
                  Admin
                </p>
              </div>
            </div>
            <button
              class="inline-flex h-10 items-center gap-2 rounded-md border border-zinc-200 px-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
              data-logout-button
              title="Cerrar sesion"
              type="button"
            >
              <LogOut size={17} />
              Salir
            </button>
          </div>
        </div>
      </header>

      <div class="space-y-6 p-4 sm:p-6">
        <p class="hidden rounded-md border px-3 py-2 text-sm" data-audit-status></p>

        <section class="grid gap-4 md:grid-cols-4">
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Registros</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-audit-count>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Entradas</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-audit-check-ins>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Pagos revisados</p>
            <p class="mt-2 text-2xl font-semibold text-zinc-950" data-audit-payment-reviews>0</p>
          </div>
          <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-medium uppercase text-zinc-500">Ultimo actor</p>
            <p class="mt-2 truncate text-2xl font-semibold text-zinc-950" data-audit-last-actor>Sin actividad</p>
          </div>
        </section>

        <section class="rounded-lg border border-zinc-200 bg-white shadow-sm">
          <div class="flex flex-col gap-3 border-b border-zinc-200 p-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-zinc-950 text-white">
                <Activity size={18} />
              </span>
              <div>
                <h2 class="text-sm font-semibold text-zinc-950">Actividad reciente</h2>
                <p class="mt-1 text-xs text-zinc-500">Lectura operativa de acciones sensibles</p>
              </div>
            </div>

            <label class="relative block">
              <Search class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400" size={16} />
              <input
                class="h-10 w-full rounded-md border border-zinc-200 bg-white pl-9 pr-3 text-sm text-zinc-950 outline-none focus:border-zinc-400 lg:w-80"
                data-audit-search
                placeholder="Buscar accion, actor o entidad"
                type="search"
              />
            </label>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-zinc-100 text-left">
              <thead class="bg-zinc-50 text-xs uppercase text-zinc-500">
                <tr>
                  <th class="px-4 py-3 font-medium">Fecha</th>
                  <th class="px-4 py-3 font-medium">Accion</th>
                  <th class="px-4 py-3 font-medium">Actor</th>
                  <th class="px-4 py-3 font-medium">Entidad</th>
                  <th class="px-4 py-3 font-medium">Estado</th>
                  <th class="px-4 py-3 font-medium">Metadata</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-100 bg-white" data-audit-body>
                <tr>
                  <td class="px-4 py-8 text-center text-sm text-zinc-500" colspan="6">
                    Cargando auditoria
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
