{
  "name": "boletas-eventos-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @boletas/api --filter @boletas/web dev",
    "dev:api": "pnpm --filter @boletas/api dev",
    "dev:web": "pnpm --filter @boletas/web dev",
    "build": "pnpm run build:shared && pnpm run build:web && pnpm run build:api",
    "build:shared": "pnpm --filter @boletas/shared build",
    "build:web": "pnpm --filter @boletas/web build",
    "build:api": "pnpm --filter @boletas/api build",
    "db:seed": "pnpm --filter @boletas/api db:seed",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @boletas/api test",
    "start": "pnpm --filter @boletas/api start:prod"
  }
}
