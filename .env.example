# App
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=https://boletas.corporacionceer.com
# Produccion con frontend en Hostinger y backend en Render.
PUBLIC_API_BASE_URL=https://api-boletas.corporacionceer.com/api

# Desarrollo local alternativo si NestJS corre en el puerto 3000.
# PUBLIC_API_BASE_URL=http://localhost:3000/api

# API
CORS_ORIGIN=http://localhost:4321,https://boletas.corporacionceer.com
WEB_DIST_PATH=apps/web/dist
UPLOADS_DIR=uploads

# Base de datos propuesta para Hostinger
# Reemplazar usuario, password, host, puerto y nombre cuando se cree MySQL en hPanel.
DATABASE_URL=mysql://usuario:password@host:3306/boletas_eventos
